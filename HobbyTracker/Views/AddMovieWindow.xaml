<Window x:Class="HobbyTracker.Views.AddMovieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:models="clr-namespace:HobbyTracker.Models"
        mc:Ignorable="d"
        Title="Film Ekle"
        Icon="/HT.ico"
        WindowState="Maximized"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- Renk Paletleri (GamesView ile uyumlu) -->
        <SolidColorBrush x:Key="BgDark" Color="#FF0C111A"/>
        <SolidColorBrush x:Key="CardDark" Color="#1a2230"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#161d2a"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2b6cee"/>
        <SolidColorBrush x:Key="TextLight" Color="#92a4c9"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2a3447"/>
        <SolidColorBrush x:Key="BorderColor" Color="#232f48"/>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Focus Border Kaldırma -->
        <Style TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="0"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Modern Button Hover Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3b7df5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1d5bd6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close İkon Hover Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#ef4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Ekranı Karart: Arka plan overlay -->
    <Grid>
        <Border Background="#99000000" MouseDown="Background_MouseDown"/>

        <!-- Ana İçerik Penceresi -->
        <Border Width="950" Height="680" Background="#FF0C111A" CornerRadius="16" 
                BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="10" Opacity="0.7"/>
            </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Search Bar -->
                <RowDefinition Height="*"/>    <!-- Content (Split View) -->
            </Grid.RowDefinitions>

            <!-- 1. HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Film İkonu -->
                    <dx:DXImage Source="/ZImages/movie.svg" Width="24" Height="24" Margin="0,0,10,0"/>
                    <TextBlock Text="Film Ekle" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource CloseButtonStyle}" Click="BtnClose_Click">
                    <TextBlock Text="✕" Foreground="{StaticResource TextLight}" FontSize="16"/>
                </Button>
            </Grid>

            <!-- 2. SEARCH BAR -->
            <Grid Grid.Row="1" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Input -->
                <Border Background="{StaticResource CardDark}" CornerRadius="10" Height="45" BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="/ZImages/search_png.png" Width="18" Height="18" Margin="15,0,5,0" VerticalAlignment="Center" Opacity="0.5"/>
                        <TextBox x:Name="TxtSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                 Foreground="White" FontSize="14" VerticalContentAlignment="Center"
                                 Margin="5,0,10,0" KeyDown="TxtSearch_KeyDown">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type TextBox}">
                                    <Setter Property="CaretBrush" Value="White"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        
                        <!-- Placeholder -->
                        <TextBlock Grid.Column="1" Text="Film adı girin..." IsHitTestVisible="False"
                                   Foreground="{StaticResource TextLight}" FontSize="14" VerticalAlignment="Center" Margin="7,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Search Button -->
                <Button x:Name="BtnSearch" Grid.Column="1" Content="Ara" Width="80" Height="45"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Margin="10,0,0,0" Click="BtnSearch_Click"/>
            </Grid>

            <!-- 3. CONTENT AREA -->
            <Grid Grid.Row="2">
                
                <!-- EMPTY STATE (Arama yapılmadan önce gösterilir) -->
                <Grid x:Name="EmptyStatePanel" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-50,0,0">
                        
                        <!-- Büyük İkon -->
                        <Border Width="100" Height="100" CornerRadius="50" Background="#1F2937" Margin="0,0,0,25">
                            <TextBlock Text="🎬" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        
                        <!-- Başlık -->
                        <TextBlock Text="Film Aramaya Başlayın" FontSize="22" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        
                        <!-- Açıklama -->
                        <TextBlock Text="Yukarıdaki arama kutusunu kullanarak izlemek istediğiniz filmi bulun." 
                                   Foreground="#9CA3AF" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" 
                                   MaxWidth="400" TextAlignment="Center" Margin="0,0,0,30"/>
                        
                        <!-- Öneri Kutucukları -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12,8" Margin="5,0" Cursor="Hand"
                                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                <TextBlock Text="🔥 Popüler Filmler" Foreground="{StaticResource TextLight}" FontSize="12"/>
                            </Border>
                            <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12,8" Margin="5,0" Cursor="Hand"
                                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                <TextBlock Text="⭐ En İyi Puanlılar" Foreground="{StaticResource TextLight}" FontSize="12"/>
                            </Border>
                            <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12,8" Margin="5,0" Cursor="Hand"
                                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                <TextBlock Text="🎞️ Yeni Çıkanlar" Foreground="{StaticResource TextLight}" FontSize="12"/>
                            </Border>
                        </StackPanel>
                        
                    </StackPanel>
                </Grid>
                
                <!-- SEARCH RESULTS PANEL (Arama yapıldıktan sonra gösterilir) -->
                <Grid x:Name="SearchResultsPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/> <!-- Sol Panel: Liste -->
                        <ColumnDefinition Width="20"/>  <!-- Boşluk -->
                        <ColumnDefinition Width="*"/>   <!-- Sağ Panel: Detay -->
                    </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: Search Results -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ARAMA SONUÇLARI" Foreground="{StaticResource TextLight}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" Background="{StaticResource CardDark}" CornerRadius="12" ClipToBounds="True"
                            BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                        <ListBox x:Name="LstMovies" Background="Transparent" BorderThickness="0" 
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="LstMovies_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border" Padding="10" Margin="0,0,0,2" CornerRadius="8" Background="Transparent" Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource CardDark}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#1E3A5A"/> <!-- Seçili Mavi -->
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                        <Setter TargetName="Border" Property="BorderThickness" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Poster Thumbnail -->
                                        <Border CornerRadius="4" Height="75" Width="50">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding PosterUrl}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding Director}" Foreground="#9CA3AF" FontSize="12"/>
                                                <TextBlock Text=" • " Foreground="#6B7280" FontSize="12"/>
                                                <TextBlock Text="{Binding Year}" Foreground="#9CA3AF" FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- Arrow Icon (Only visible when selected ideally, but let's keep it simple) -->
                                        <TextBlock Grid.Column="2" Text="›" Foreground="#60A5FA" FontSize="20" 
                                                   VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    
                    <!-- Loading Indicator -->
                    <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Height="2" VerticalAlignment="Top" 
                                 Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Visibility="Collapsed"/>
                </Grid>

                <!-- RIGHT PANEL: Details & Form -->
                <Grid Grid.Column="2" x:Name="DetailPanel" Visibility="Hidden">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Top Details -->
                        <RowDefinition Height="*"/>    <!-- Form Fields -->
                        <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Top Details -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Large Poster -->
                        <Border CornerRadius="8" Height="180">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                            </Border.Effect>
                            <Border.Background>
                                <ImageBrush x:Name="ImgPoster" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        
                        <!-- Info -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock x:Name="TxtTitle" Text="Interstellar" FontSize="28" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                            
                            <!-- Tags -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,15">
                                <Border Background="#1F2937" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                    <TextBlock x:Name="TxtGenre" Text="Bilim Kurgu" Foreground="#9CA3AF" FontSize="11"/>
                                </Border>
                                <Border Background="#1F2937" CornerRadius="4" Padding="8,4">
                                    <TextBlock x:Name="TxtDuration" Text="2h 49m" Foreground="#9CA3AF" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            
                            <TextBlock x:Name="TxtSynopsis" Text="İnsanlık, yok olma tehlikesiyle karşı karşıyadır..." 
                                       Foreground="#D1D5DB" TextWrapping="Wrap" LineHeight="20" 
                                       MaxHeight="80" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>

                    <!-- Form Fields -->
                    <Border Grid.Row="1" Background="#1F2937" CornerRadius="12" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1: Status & Rating -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status -->
                                <StackPanel>
                                    <TextBlock Text="İzleme Durumu" Foreground="{StaticResource TextLight}" FontSize="12" Margin="0,0,0,8"/>
                                    <Border Height="44" CornerRadius="8" Background="{StaticResource CardDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                        <ComboBox x:Name="CmbStatus" Background="Transparent" BorderThickness="0" 
                                                  Foreground="White" VerticalContentAlignment="Center" Padding="12,0"
                                                  SelectionChanged="CmbStatus_SelectionChanged">
                                            <ComboBoxItem Content="İzlendi"/>
                                            <ComboBoxItem Content="İzleniyor"/>
                                            <ComboBoxItem Content="Listem" IsSelected="True"/>
                                            <ComboBoxItem Content="Yarım Bırakıldı"/>
                                        </ComboBox>
                                    </Border>
                                </StackPanel>

                                <!-- Rating with Star Popup -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Puanım" Foreground="{StaticResource TextLight}" FontSize="12" Margin="0,0,0,8"/>
                                    
                                    <!-- Star Popup -->
                                    <Popup x:Name="StarPopup"
                                           PlacementTarget="{Binding ElementName=BtnStarSelect}"
                                           Placement="Bottom"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade"
                                           VerticalOffset="6">
                                        <Border Background="{StaticResource CardDark}" CornerRadius="10" Padding="12" 
                                                BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" x:Name="StarContainer">
                                                <!-- Stars will be created dynamically in code-behind -->
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                    
                                    <!-- Star Select Button -->
                                    <Border x:Name="BtnStarSelect" Height="44" CornerRadius="8" Background="{StaticResource CardDark}" 
                                            BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                            Cursor="Hand" MouseLeftButtonUp="BtnStarSelect_MouseUp">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtStarRating" Text="0/10" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Date Picker -->
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="İzlenme Tarihi" Foreground="{StaticResource TextLight}" FontSize="12" Margin="0,0,0,8"/>
                                <Border Height="44" CornerRadius="8" Background="{StaticResource CardDark}" 
                                        BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                        Cursor="Hand" PreviewMouseDown="DateInput_PreviewMouseDown">
                                    <Grid>
                                        <dx:DXImage Source="{dx:DXImage 'SvgImages/Scheduling/Calendar.svg'}" Width="18" HorizontalAlignment="Left" Margin="12,0,0,0" Opacity="0.7" Panel.ZIndex="1"/>
                                        <dxe:DateEdit x:Name="DtDate" ShowBorder="False" Height="44" Background="Transparent" Foreground="White" 
                                                      AllowDefaultButton="False" NullText="gg.aa.yyyy" Margin="35,0,10,0" HorizontalContentAlignment="Left"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Action Buttons -->
                    <Button x:Name="BtnAdd" Grid.Row="2" Content="+ Listeme Ekle" Height="50" Margin="0,20,0,0"
                            Style="{StaticResource PrimaryButtonStyle}" FontSize="16" Click="BtnAdd_Click"/>

                </Grid>
                </Grid> <!-- End of SearchResultsPanel -->
            </Grid> <!-- End of CONTENT AREA Grid -->
        </Grid> <!-- End of Main Grid with Margin=25 -->
    </Border>
    </Grid> <!-- End of Outer Wrapper Grid -->

</Window>
