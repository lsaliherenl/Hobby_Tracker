<UserControl x:Class="HobbyTracker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:models="clr-namespace:HobbyTracker.Models;assembly=HobbyTracker"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Animasyon -->
        <Storyboard x:Key="SlideUpFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Kart Stili -->
        <Style x:Key="InteractiveCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3b82f6"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#3b82f6" BlurRadius="20" Opacity="0.4" ShadowDepth="5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sekme Base Stili -->
        <Style x:Key="TabRadioButtonBaseStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        
        <!-- Genel Bakış - Mavi -->
        <Style x:Key="TabBlueStyle" TargetType="RadioButton" BasedOn="{StaticResource TabRadioButtonBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3b82f6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#2563eb"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Oyunlar - Mor -->
        <Style x:Key="TabPurpleStyle" TargetType="RadioButton" BasedOn="{StaticResource TabRadioButtonBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#8b5cf6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#7c3aed"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Kitaplar - Turuncu -->
        <Style x:Key="TabOrangeStyle" TargetType="RadioButton" BasedOn="{StaticResource TabRadioButtonBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#f97316"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#ea580c"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Sinema & TV - Kırmızı -->
        <Style x:Key="TabRedStyle" TargetType="RadioButton" BasedOn="{StaticResource TabRadioButtonBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#ef4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#dc2626"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Vitrin - Sarı/Yeşil -->
        <Style x:Key="TabYellowStyle" TargetType="RadioButton" BasedOn="{StaticResource TabRadioButtonBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#eab308"/>
                                <Setter Property="Foreground" Value="#1a1a2e"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#ca8a04"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Devam Et Kartı Stili -->
        <Style x:Key="ContinueCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#283548"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Progress Bar Style -->
        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="MaxHeight" Value="6"/>
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" Height="6">
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3" Height="6"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3" Height="6">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Path=Foreground.(SolidColorBrush.Color), RelativeSource={RelativeSource TemplatedParent}}" 
                                                      BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bool to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Yeni Eklenen Satır Stili -->
        <Style x:Key="RecentRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#283548"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- İstatistik Kartları Hover Stili -->
        <Style x:Key="StatsCardHoverStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <Grid x:Name="RootGrid" Background="Transparent" Margin="30,30,30,50">
            <Grid.RenderTransform>
                <TranslateTransform Y="20"/>
            </Grid.RenderTransform>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource SlideUpFadeIn}"/>
                </EventTrigger>
            </Grid.Triggers>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- HEADER: Karşılama ve Sekmeler -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Karşılama Metni -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="WelcomeText" Text="Tekrar Hoş Geldin!" FontSize="26" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="İşte bu haftaki aktivite özetin." FontSize="14" Foreground="#94a3b8" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Sekmeler -->
            <Border Grid.Row="1" Background="#1e293b" CornerRadius="12" Padding="5" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TabGenelBakis" Content="GENEL BAKIŞ" 
                                 Style="{StaticResource TabBlueStyle}" 
                                 IsChecked="True" GroupName="DashboardTabs"
                                 Checked="Tab_Checked" Margin="5,0,5,0"
                                 Tag="#3b82f6"/>
                    <RadioButton x:Name="TabOyunlar" Content="OYUNLAR" 
                                 Style="{StaticResource TabPurpleStyle}" 
                                 GroupName="DashboardTabs"
                                 Checked="Tab_Checked" Margin="5,0,5,0"
                                 Tag="#8b5cf6"/>
                    <RadioButton x:Name="TabKitaplar" Content="KİTAPLAR" 
                                 Style="{StaticResource TabOrangeStyle}" 
                                 GroupName="DashboardTabs"
                                 Checked="Tab_Checked" Margin="5,0,5,0"
                                 Tag="#f97316"/>
                    <RadioButton x:Name="TabSinema" Content="SİNEMA &amp; TV" 
                                 Style="{StaticResource TabRedStyle}" 
                                 GroupName="DashboardTabs"
                                 Checked="Tab_Checked" Margin="5,0,5,0"
                                 Tag="#ef4444"/>
                    <RadioButton x:Name="TabVitrin" Content="VİTRİN" 
                                 Style="{StaticResource TabYellowStyle}" 
                                 GroupName="DashboardTabs"
                                 Checked="Tab_Checked" Margin="5,0,5,0"
                                 Tag="#eab308"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- İSTATİSTİK KARTLARI -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bitirilen Oyunlar - Mor Tema -->
            <Border Grid.Column="0" Style="{StaticResource StatsCardHoverStyle}" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                         <GradientStop Color="#CC1e293b" Offset="0"/>
                         <GradientStop Color="#0f1425" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#334155" Offset="0"/>
                        <GradientStop Color="#a78bfa" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#a78bfa" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <Border.BorderThickness>1</Border.BorderThickness>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🎮" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Bitirilen Oyunlar" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Stats.FinishedGames, FallbackValue=0}" Foreground="#a78bfa" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="↗" Foreground="#10b981" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Stats.TotalGames, StringFormat='Toplam {0} oyun', FallbackValue='Toplam 0 oyun'}" 
                               Foreground="#64748b" FontSize="11" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Okunan Kitaplar - Turuncu Tema -->
            <Border Grid.Column="1" Style="{StaticResource StatsCardHoverStyle}" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                         <GradientStop Color="#CC1e293b" Offset="0"/>
                         <GradientStop Color="#0f1425" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#334155" Offset="0"/>
                        <GradientStop Color="#fb923c" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#fb923c" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <Border.BorderThickness>1</Border.BorderThickness>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="📚" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Okunan Kitaplar" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Stats.ReadBooks, FallbackValue=0}" Foreground="#fb923c" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="↗" Foreground="#10b981" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Stats.TotalBooks, StringFormat='Toplam {0} kitap', FallbackValue='Toplam 0 kitap'}" 
                               Foreground="#64748b" FontSize="11" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Toplam İzleme - Kırmızı Tema -->
            <Border Grid.Column="2" Style="{StaticResource StatsCardHoverStyle}" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <Border.Background>
                     <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                         <GradientStop Color="#CC1e293b" Offset="0"/>
                         <GradientStop Color="#0f1425" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#334155" Offset="0"/>
                        <GradientStop Color="#ef4444" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#ef4444" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <Border.BorderThickness>1</Border.BorderThickness>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🎬" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Toplam İzleme" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Stats.TotalWatchHours, FallbackValue=0}" Foreground="#ef4444" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="sa" Foreground="#ef4444" FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,4" Opacity="0.7"/>
                        <TextBlock Text="↗" Foreground="#10b981" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    <TextBlock Foreground="#64748b" FontSize="11" Margin="0,10,0,0">
                        <Run Text="{Binding Stats.WatchedMovies, FallbackValue=0, Mode=OneWay}"/>
                        <Run Text=" film,"/>
                        <Run Text="{Binding Stats.TotalEpisodesWatched, FallbackValue=0, Mode=OneWay}"/>
                        <Run Text=" bölüm"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Mevcut Seri - Yeşil Tema -->
            <Border Grid.Column="3" Style="{StaticResource StatsCardHoverStyle}" CornerRadius="12" Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                         <GradientStop Color="#CC1e293b" Offset="0"/>
                         <GradientStop Color="#0f1425" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#334155" Offset="0"/>
                        <GradientStop Color="#4ade80" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#4ade80" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <Border.BorderThickness>1</Border.BorderThickness>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🔥" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Mevcut Seri" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Stats.ActivityStreak, FallbackValue=0}" Foreground="#4ade80" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="gün" Foreground="#4ade80" FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,4" Opacity="0.7"/>
                        <TextBlock Text="→" Foreground="#94a3b8" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.6"/>
                    </StackPanel>
                    <TextBlock Text="Ardışık aktivite günü" Foreground="#64748b" FontSize="11" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- KALDIĞIN YERDEN DEVAM ET + GRAFİK -->
        <Grid Grid.Row="2" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Kaldığın Yerden Devam Et -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Grid Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Kaldığın Yerden Devam Et" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                <!-- Dinamik Devam Kartları -->
                <ItemsControl x:Name="ContinueItemsControl" ItemsSource="{Binding ContinueItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" Rows="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ContinueCardStyle}" Margin="0,0,15,15" Height="200"
                                    PreviewMouseLeftButtonDown="ContinueItem_Click">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Kapak Resmi -->
                                    <Border Grid.Row="0" CornerRadius="12,12,0,0" Margin="5,5,5,0">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding CoverUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                        <!-- Kategori Badge -->
                                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" 
                                                CornerRadius="4" Padding="6,3" Margin="8,8,0,0"
                                                Background="{Binding CategoryColor}">
                                            <TextBlock Text="{Binding Category}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Border>

                                    <!-- İçerik Bilgisi -->
                                    <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="14" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <!-- İlerleme Barı (Oyunlar hariç) -->
                                        <Grid Margin="0,8,0,0" Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Grid.Column="0" Value="{Binding Progress}" Maximum="100"
                                                         Style="{StaticResource ModernProgressBarStyle}">
                                                <ProgressBar.Foreground>
                                                    <SolidColorBrush Color="{Binding CategoryColor}"/>
                                                </ProgressBar.Foreground>
                                            </ProgressBar>
                                            <TextBlock Grid.Column="1" Text="{Binding ProgressText}" Foreground="#94a3b8" FontSize="11" 
                                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        
                                        <!-- Oynama Süresi (Sadece Oyunlar için) -->
                                        <TextBlock Text="{Binding PlayTimeText}" Foreground="#94a3b8" FontSize="11" 
                                                   Margin="0,8,0,0"
                                                   Visibility="{Binding ShowPlayTime, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Boş Durum -->
                <Border x:Name="EmptyContinueState" Background="#1e293b" CornerRadius="12" 
                        Height="200" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📚" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="Devam edecek içerik yok" Foreground="#94a3b8" FontSize="14" 
                                   Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bir içerik ekleyerek başlayın" Foreground="#64748b" FontSize="12" 
                                   Margin="0,5,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Aktivite Grafiği - Futuristik Glassmorphism Design -->
            <!-- Aktivite Grafiği - Futuristik Glassmorphism Design -->
            <Border Grid.Column="1" CornerRadius="16" Padding="24">
                <!-- Glassmorphism Background -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                         <GradientStop Color="#CC1e293b" Offset="0"/>
                         <GradientStop Color="#0f1425" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <!-- Neon Border Glow -->
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#334155" Offset="0"/>
                        <GradientStop Color="#3b82f6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect Color="#3b82f6" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header Row -->
                    <Grid Grid.Row="0">
                        <TextBlock Text="Haftalık Aktivite" Foreground="#FF3B82F6" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Son 7 Gün" Foreground="#3b82f6" FontSize="12" FontWeight="Medium" 
                                   HorizontalAlignment="Right" Cursor="Hand"/>
                    </Grid>

                    <!-- Stats Row with Neon Number -->
                    <Grid Grid.Row="1" Margin="0,16,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Big Number with Glow Effect -->
                        <TextBlock Grid.Column="0" FontSize="36" FontWeight="Bold" VerticalAlignment="Bottom">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#60a5fa" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#3b82f6" BlurRadius="10" Opacity="0.5" ShadowDepth="0"/>
                            </TextBlock.Effect>
                            <Run Text="{Binding Stats.TotalItems, FallbackValue=51, Mode=OneWay}"/>
                        </TextBlock>
                        
                        <StackPanel Grid.Column="1" Margin="8,0,0,4" VerticalAlignment="Bottom">
                            <TextBlock Text="İçerik" FontSize="14" Foreground="#94a3b8" VerticalAlignment="Bottom"/>
                        </StackPanel>
                        
                        <!-- Trend Arrow -->
                        <Border Grid.Column="2" HorizontalAlignment="Left" Margin="12,0,0,4" VerticalAlignment="Bottom"
                                Background="#10b98120" CornerRadius="4" Padding="6,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↗" Foreground="#10b981" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="10%" Foreground="#10b981" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Subtitle -->
                    <TextBlock Grid.Row="1" Foreground="#64748b" FontSize="12" Margin="0,60,0,0" VerticalAlignment="Bottom">
                        <Run Text="{Binding Stats.TotalItems, FallbackValue=51, Mode=OneWay}"/>
                        <Run Text=" içerik tüketildi, toplam"/>
                        <Run Text="{Binding Stats.GetTotalHoursSpent, FallbackValue=14, Mode=OneWay}"/>
                        <Run Text=" saat"/>
                    </TextBlock>

                    <!-- DevExpress Spline Area Chart - Yuvarlak Köşeli -->
                    <Border Grid.Row="2" CornerRadius="12" ClipToBounds="True" 
                            Margin="0,5,0,0" Background="#0d1220">
                        <dxc:ChartControl x:Name="ActivityChart"
                                          Background="Transparent" 
                                          Margin="0" MinHeight="140"
                                          BorderThickness="0"
                                          AnimationMode="OnDataChanged" BorderBrush="{x:Null}">
                            <dxc:ChartControl.CrosshairOptions>
                                <dxc:CrosshairOptions ShowArgumentLabels="True" 
                                                       ShowValueLabels="True"
                                                       ShowArgumentLine="False"
                                                       ShowValueLine="False"
                                                       LinesMode="Auto"/>
                            </dxc:ChartControl.CrosshairOptions>
                            <dxc:XYDiagram2D Background="Transparent">
                                <dxc:XYDiagram2D.DefaultPane>
                                    <!-- Arka plan şeffaf - Border'dan geliyor -->
                                    <dxc:Pane Background="Transparent" 
                                              BorderBrush="Transparent"
                                              DomainBrush="Transparent" DomainBorderBrush="{x:Null}"/>
                                </dxc:XYDiagram2D.DefaultPane>
                                <dxc:XYDiagram2D.AxisX>
                                    <dxc:AxisX2D TickmarksVisible="False" 
                                                 GridLinesVisible="False"
                                                 Brush="Transparent"
                                                 Interlaced="False">
                                        <dxc:AxisX2D.Label>
                                            <dxc:AxisLabel Foreground="#64748b" FontSize="10"/>
                                        </dxc:AxisX2D.Label>
                                    </dxc:AxisX2D>
                                </dxc:XYDiagram2D.AxisX>
                                <dxc:XYDiagram2D.AxisY>
                                    <!-- Y ekseni görünür ve etiketli -->
                                    <dxc:AxisY2D Visible="True" 
                                                 GridLinesVisible="True"
                                                 GridLinesBrush="#1e2847"
                                                 Brush="Transparent"
                                                 TickmarksVisible="False"
                                                 Interlaced="False"
                                                 InterlacedBrush="Transparent">
                                        <dxc:AxisY2D.Label>
                                            <dxc:AxisLabel Foreground="#64748b" FontSize="10"/>
                                        </dxc:AxisY2D.Label>
                                    </dxc:AxisY2D>
                                </dxc:XYDiagram2D.AxisY>
                                <!-- Spline Area Series with Neon Blue -->
                                <dxc:SplineAreaSeries2D x:Name="ActivitySeries"
                                                         DisplayName="Aktivite"
                                                         MarkerVisible="True"
                                                         MarkerSize="6"
                                                         LabelsVisibility="False"
                                                         Brush="#503b82f6">
                                </dxc:SplineAreaSeries2D>
                            </dxc:XYDiagram2D>
                            <dxc:ChartControl.Legend>
                                <dxc:Legend Visible="False"/>
                            </dxc:ChartControl.Legend>
                        </dxc:ChartControl>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- YENİ EKLENENLER -->
        <Grid Grid.Row="3">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Yeni Eklenenler" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                <Border CornerRadius="15" Padding="0,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                             <GradientStop Color="#CC1e293b" Offset="0"/>
                             <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#3b82f6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#3b82f6" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <!-- Tablo Başlığı -->
                        <Grid Margin="20,10" Opacity="0.5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="BAŞLIK" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="KATEGORİ" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="EKLENDİĞİ TARİH" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="DURUM" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Grid>

                        <Separator Background="#334155" Margin="0,5,0,5"/>

                        <!-- Dinamik Liste -->
                        <ItemsControl x:Name="RecentItemsControl" ItemsSource="{Binding RecentItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource RecentRowStyle}" Padding="20,12" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Kapak Resmi -->
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" 
                                                    HorizontalAlignment="Left">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding CoverUrl}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- Başlık -->
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="White" 
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- Kategori Badge -->
                                            <Border Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    CornerRadius="5" Padding="8,4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding CategoryColor}" Opacity="0.2"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Category}" FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding CategoryColor}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>

                                            <!-- Tarih -->
                                            <TextBlock Grid.Column="3" Text="{Binding AddedDateShort}" 
                                                       Foreground="#94a3b8" VerticalAlignment="Center"/>

                                            <!-- Durum -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding CategoryColor}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" FontWeight="SemiBold">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding CategoryColor}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Boş Durum -->
                        <Border x:Name="EmptyRecentState" Padding="40" Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🎯" FontSize="40" HorizontalAlignment="Center"/>
                                <TextBlock Text="Henüz içerik eklenmemiş" Foreground="#94a3b8" FontSize="14" 
                                           Margin="0,10,0,0" HorizontalAlignment="Center"/>
                                <TextBlock Text="Film, dizi, oyun veya kitap ekleyerek başlayın" Foreground="#64748b" FontSize="12" 
                                           Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- DİNAMİK SEKME İÇERİĞİ -->
        <ContentControl x:Name="TabContent" Grid.Row="1" Visibility="Collapsed"/>
    </Grid>
    </ScrollViewer>
</UserControl>
