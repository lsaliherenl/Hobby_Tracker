<UserControl x:Class="HobbyTracker.Views.Dashboard.DashboardKitaplarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d" 
             d:DesignHeight="950" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Sayfa Yüklenme Animasyonu -->
        <Storyboard x:Key="SlideUpFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Hover Efekti için Stil (DashboardView'dan esinlenildi) -->
        <Style x:Key="StatsCardHoverStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SlideUpFadeIn}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="RootGrid" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. İSTATİSTİKLER -->
            <Grid Grid.Row="0" Margin="0,5,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Toplam Kitap -->
                <Border Grid.Column="0" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC1e293b" Offset="0"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#f97316" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#f97316" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📚" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Toplam Kitap" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TotalBooksText" Text="0" Foreground="#60a5fa" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Kütüphanede" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Okunan -->
                <Border Grid.Column="1" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC1e293b" Offset="0"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#10b981" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#10b981" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="✅" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Okunan" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ReadBooksText" Text="0" Foreground="#10b981" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="↗" Foreground="#10b981" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" Opacity="0.8"/>
                        </StackPanel>
                        <TextBlock x:Name="CompletionRateText" Text="%0 tamamlanma" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Okunuyor -->
                <Border Grid.Column="2" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC1e293b" Offset="0"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#fb923c" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#fb923c" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📖" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Okunuyor" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ReadingBooksText" Text="0" Foreground="#fb923c" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Aktif okuma" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ortalama Puan -->
                <Border Grid.Column="4" CornerRadius="10" Padding="15" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC1e293b" Offset="0"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#fbbf24" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#fbbf24" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⭐" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ort. Puan" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="AvgRatingText" Text="0.0" Foreground="#fbbf24" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="/10" Foreground="#fbbf24" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,4" Opacity="0.7"/>
                        </StackPanel>
                        <TextBlock Text="Kullanıcı puanı" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Toplam Sayfa -->
                <Border Grid.Column="3" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC1e293b" Offset="0"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#a78bfa" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#a78bfa" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Toplam Sayfa" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TotalPagesText" Text="0" Foreground="#a78bfa" FontSize="28" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="Okunan sayfa" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 2. SON EKLENENLER & PUAN ANALİZİ (YER DEĞİŞTİ) -->
            <Grid Grid.Row="1" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <!-- Son Eklenenler -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <!-- Puan Analizi -->
                </Grid.ColumnDefinitions>

                <!-- Son Eklenenler -->
                <StackPanel Grid.Column="0" Margin="6,0,26,0">
                    <Grid Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Son Eklenenler" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Tümünü Gör Butonu -->
                        <Button HorizontalAlignment="Left" VerticalAlignment="Center" 
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="ViewAllBooks_Click" Margin="728,0,0,0" Width="71">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="Tümünü Gör" Foreground="#3b82f6" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <ItemsControl x:Name="RecentBooksControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Kitap Kartı Tasarımı (Büyütülmüş) -->
                                <Border Width="175" Margin="0,0,15,0" Padding="0" Background="#1e293b" CornerRadius="12" Cursor="Hand"
                                        PreviewMouseLeftButtonDown="OpenBookDetails_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <!-- Cover -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Info -->
                                        </Grid.RowDefinitions>

                                        <!-- Kapak Resmi -->
                                        <Border Grid.Row="0" Height="240" CornerRadius="12,12,0,0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding CoverImageUrl}" Stretch="UniformToFill"/>
                                            </Border.Background>

                                            <!-- Sayfa Sayısı Badge -->
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                                    Background="#f97316" CornerRadius="4" Padding="5,3">
                                                <TextBlock Text="{Binding PageCount, StringFormat={}{0} sf}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Border>

                                        <!-- Başlık ve Bilgi -->
                                        <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" 
                                                       TextTrimming="CharacterEllipsis" FontSize="13" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Authors}" Foreground="#94a3b8" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Boş Durum -->
                    <Border x:Name="EmptyBooksState" Padding="30" Visibility="Collapsed" Background="#1e293b" CornerRadius="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📚" FontSize="30" HorizontalAlignment="Center"/>
                            <TextBlock Text="Henüz kitap eklenmemiş" Foreground="#94a3b8" FontSize="12" 
                                       Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Puan Analizi (Buraya Taşındı ve Yenilendi) -->
                <!-- Puan Analizi (Yenilendi) -->
                <Border Grid.Column="2" CornerRadius="16" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#FF482E1B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#303b5c" Offset="0"/>
                            <GradientStop Color="#1e2847" Offset="0.5"/>
                            <GradientStop Color="#f97316" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#f97316" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25" HorizontalAlignment="Center">
                            <TextBlock Text="⭐" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#FFF97316"/>
                            <TextBlock Text="Puan Analizi" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,25">
                            <TextBlock x:Name="AnalysisAvgRating" Text="0.0" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                            <!-- Yıldızlar -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="★  ★  ★  ★  ★" Foreground="#fbbf24" FontSize="18"/>
                            </StackPanel>

                            <TextBlock x:Name="TotalRatingsCount" Text="0 DEĞERLENDİRME" Foreground="#64748b" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.8"/>
                        </StackPanel>

                        <!-- Rating Barları -->
                        <ItemsControl x:Name="RatingDistributionControl" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Star}" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>

                                        <!-- Bar Background -->
                                        <Grid Grid.Column="1" Height="8">
                                            <Border Background="#334155" CornerRadius="4"/>
                                            <Border HorizontalAlignment="Left" Width="{Binding Width}" CornerRadius="4">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#f97316" Offset="0"/>
                                                        <GradientStop Color="#fbbf24" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 3. GRAFİKLER VE ANALİZLER (KALINLIK ANALİZİ BURAYA GELDİ) -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- SOL SÜTUN: Kalınlık Analizi (Buraya Taşındı) -->
                <StackPanel Grid.Column="0">
                    <Border CornerRadius="16" Padding="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1a1f35" Offset="0"/>
                                <GradientStop Color="#141a2e" Offset="0.5"/>
                                <GradientStop Color="#FF482E1B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#303b5c" Offset="0"/>
                                <GradientStop Color="#1e2847" Offset="0.5"/>
                                <GradientStop Color="#f97316" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#f97316" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <TextBlock Text="Il" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#f97316"/>
                                <TextBlock Text="Kalınlık Analizi" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>

                            <!-- Basit Bar Chart -->
                            <Grid Height="180" VerticalAlignment="Bottom">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- <300 -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="10,0">
                                    <Border x:Name="BarLess300" Background="#fbbf24" CornerRadius="6,6,0,0" Height="0"/>
                                    <TextBlock Text="&lt;300" Foreground="#64748b" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- 300-500 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0">
                                    <Border x:Name="Bar300to500" Background="#f97316" CornerRadius="6,6,0,0" Height="0"/>
                                    <TextBlock Text="300-500" Foreground="#64748b" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- >500 -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="10,0">
                                    <Border x:Name="BarMore500" Background="#475569" CornerRadius="6,6,0,0" Height="0"/>
                                    <TextBlock Text="&gt;500" Foreground="#64748b" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Kitap Hedefim (Yeni Eklendi) -->
                    <Border CornerRadius="16" Padding="20" Margin="0,20,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1a1f35" Offset="0"/>
                                <GradientStop Color="#141a2e" Offset="0.5"/>
                                <GradientStop Color="#FF482E1B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#303b5c" Offset="0"/>
                                <GradientStop Color="#1e2847" Offset="0.5"/>
                                <GradientStop Color="#f97316" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#f97316" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>

                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎯" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#FFF97316"/>
                                    <TextBlock Text="Kitap Hedefim" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                                <dx:SimpleButton x:Name="BtnEditGoal" HorizontalAlignment="Right" Glyph="/ZImages/pencil.svg" BorderThickness="0"
                                             Width="24" Height="24" Opacity="0.5" Background="Transparent" Cursor="Hand" Click="BtnEditGoal_Click" GlyphHeight="20" GlyphWidth="20"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock x:Name="TxtFinishedCount" Text="0" FontSize="36" FontWeight="ExtraBold" Foreground="White" Margin="0,-6,0,0"/>
                                <TextBlock x:Name="TxtTotalGoal" Text="/ 24 Kitap" FontSize="14" Foreground="#94a3b8" VerticalAlignment="Bottom" Margin="6,0,0,7"/>
                            </StackPanel>

                            <Grid Height="8" Margin="0,0,0,15">
                                <Border Background="#334155" CornerRadius="4"/>
                                <Border x:Name="ProgressGoal" Background="#f97316" CornerRadius="4" HorizontalAlignment="Left" Width="0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#f97316" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>

                            <TextBlock x:Name="TxtGoalMessage" Text="Henüz başlamadın. Hadi bir kitap bitir!" 
                                   FontSize="12" Foreground="#94a3b8" TextWrapping="Wrap" LineHeight="18"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- SAĞ SÜTUN: Sayfa Performansı & Favori Yazarlar -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sayfa Performansı (Line Chart) -->
                    <Border Grid.Row="0" CornerRadius="16" Padding="20" Margin="0,0,0,20">
                        <!-- Glassmorphism Background -->
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1a1f35" Offset="0"/>
                                <GradientStop Color="#141a2e" Offset="0.5"/>
                                <GradientStop Color="#FF482E1B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#303b5c" Offset="0"/>
                                <GradientStop Color="#1e2847" Offset="0.5"/>
                                <GradientStop Color="#f97316" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#f97316" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>
                        <Border.BorderThickness>1</Border.BorderThickness>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="📈" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#FFF97316"/>
                                <TextBlock Text="Sayfa Performansı" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <Border Background="#334155" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Son 6 Ay" Foreground="#94a3b8" FontSize="9"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Toplam Sayfa" Foreground="#64748b" FontSize="10"/>
                                    <TextBlock x:Name="PerformansTotalPages" Text="0" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Ortalama" Foreground="#64748b" FontSize="10"/>
                                    <TextBlock x:Name="PerformansAvgPages" Text="0 /ay" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Line Chart -->
                            <dxc:ChartControl x:Name="PagePerformanceChart" Grid.Row="2" Height="200" 
                                              Background="Transparent" BorderThickness="0" BorderBrush="{x:Null}">
                                <dxc:XYDiagram2D>
                                    <dxc:XYDiagram2D.DefaultPane>
                                        <dxc:Pane DomainBrush="Transparent" DomainBorderBrush="{x:Null}"/>
                                    </dxc:XYDiagram2D.DefaultPane>
                                    <dxc:XYDiagram2D.AxisX>
                                        <dxc:AxisX2D GridLinesVisible="False" Interlaced="False">
                                            <dxc:AxisX2D.Label>
                                                <dxc:AxisLabel Foreground="#94a3b8" FontSize="10"/>
                                            </dxc:AxisX2D.Label>
                                        </dxc:AxisX2D>
                                    </dxc:XYDiagram2D.AxisX>
                                    <dxc:XYDiagram2D.AxisY>
                                        <dxc:AxisY2D GridLinesVisible="False" Interlaced="False" Visible="False"/>
                                    </dxc:XYDiagram2D.AxisY>
                                    <dxc:LineSeries2D x:Name="PageSeries" DisplayName="Sayfa" 
                                                      ArgumentDataMember="MonthName" ValueDataMember="PageCount"
                                                      Brush="#f97316" MarkerVisible="True" MarkerSize="10">
                                        <dxc:LineSeries2D.LineStyle>
                                            <dxc:LineStyle Thickness="2"/>
                                        </dxc:LineSeries2D.LineStyle>
                                    </dxc:LineSeries2D>
                                </dxc:XYDiagram2D>
                            </dxc:ChartControl>
                        </Grid>
                    </Border>

                    <!-- Favori Yazarlar -->
                    <Border Grid.Row="1" CornerRadius="16" Padding="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1a1f35" Offset="0"/>
                                <GradientStop Color="#141a2e" Offset="0.5"/>
                                <GradientStop Color="#FF482E1C" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#303b5c" Offset="0"/>
                                <GradientStop Color="#1e2847" Offset="0.5"/>
                                <GradientStop Color="#f97316" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#f97316" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#FFF97316"/>
                                    <TextBlock Text="Favori Yazarlar" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl x:Name="FavoriteAuthorsControl" Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar Placeholder -->
                                            <Border Width="36" Height="36" CornerRadius="18" Background="#334155" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="★" Foreground="#fbbf24" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding AvgRating, StringFormat=F1}" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BookCount}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                                <TextBlock Text="Kitap" Foreground="#64748b" FontSize="10" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Boş Durum -->
                            <TextBlock x:Name="EmptyAuthorsText" Grid.Row="1" Text="Yeterli veri yok" 
                                       Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 4. FAVORİ OYUNLAR & EN UZUN SERÜVEN -->
            <Grid Grid.Row="3" Margin="0,20,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SOL PANEL: Favori Kitaplar (Carousel) -->
                <Border Grid.Column="0" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="CurrentFavorite_Click">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding CurrentFavoriteBook.CoverImageUrl}" Stretch="UniformToFill" Opacity="0.4"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Border Background="#CC0f172a" CornerRadius="16"/>
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Navigasyon Butonları (Overlay) -->
                            <Button Grid.RowSpan="3" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Click="PrevFavorite_Click">
                                <TextBlock Text="❮" Foreground="White" FontSize="20" FontWeight="Bold" Opacity="0.7"/>
                            </Button>
                            <Button Grid.RowSpan="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Click="NextFavorite_Click">
                                <TextBlock Text="❯" Foreground="White" FontSize="20" FontWeight="Bold" Opacity="0.7"/>
                            </Button>

                            <!-- Header -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="❤️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#FFF97316"/>
                                <TextBlock Text="Favori Kitaplar" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Yıl/Sayfa Badge (Sağ Üst) -->
                            <Border Grid.Row="0" HorizontalAlignment="Right" Background="#334155" CornerRadius="6" Padding="8,4"
                                     Visibility="{Binding HasNoFavorites, Converter={dx:BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                                <TextBlock Text="{Binding CurrentFavoriteBook.PublishYear}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <!-- Kitap Bilgisi -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="15">
                                <TextBlock Text="{Binding CurrentFavoriteBook.Title}" Foreground="White" FontSize="24" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                <TextBlock Foreground="#94a3b8" FontSize="13">
                                    <Run Text="{Binding CurrentFavoriteBook.Authors}"/>
                                    <Run Text=" • "/>
                                    <Run Text="{Binding CurrentFavoriteBook.PageCount}"/>
                                    <Run Text=" sayfa"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Alt İstatistikler -->
                            <Grid Grid.Row="2" Margin="15,0,15,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <TextBlock Text="DURUM" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentFavoriteBook.StatusDisplay}" Foreground="#60a5fa" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="KİŞİSEL PUAN" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding CurrentFavoriteBook.UserRating}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="Detayları Gör" Foreground="#60a5fa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="→" Foreground="#60a5fa" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- Boş Durum -->
                            <TextBlock Grid.Row="1" Text="Henüz favori kitap eklenmemiş." 
                                       Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding HasNoFavorites, Converter={dx:BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- SAĞ PANEL: En Uzun Serüven -->
                <Border Grid.Column="2" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="LongestBook_Click">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding LongestBook.CoverImageUrl}" Stretch="UniformToFill" Opacity="0.4"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Border Background="#CC0f172a" CornerRadius="16"/>
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Sol: Kapak -->
                                <ColumnDefinition Width="*"/>
                                <!-- Sağ: Bilgiler -->
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="0" Height="0"/>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" HorizontalAlignment="Left" Background="#fbbf24" CornerRadius="6" Padding="8,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏆" FontSize="12" Margin="0,0,5,0"/>
                                        <TextBlock Text="En Uzun Serüven" Foreground="Black" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" HorizontalAlignment="Right" Background="#334155" CornerRadius="6" Padding="8,4">
                                    <TextBlock Text="{Binding LongestBook.Authors}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>

                                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,15">
                                    <TextBlock Text="{Binding LongestBook.Title}" Foreground="White" FontSize="20" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                    <TextBlock Foreground="#94a3b8" FontSize="14">
                                        <Run Text="{Binding LongestBook.PageCount}"/>
                                        <Run Text=" sayfa"/>
                                    </TextBlock>
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <TextBlock Text="DURUM" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding LongestBook.StatusDisplay}" Foreground="#60a5fa" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="KİŞİSEL PUAN" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding LongestBook.UserRating}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="Detayları Gör" Foreground="#60a5fa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="→" Foreground="#60a5fa" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Hedef Belirleme Popup (Overlay) -->
            <Popup x:Name="GoalPopup" PlacementTarget="{Binding ElementName=BtnEditGoal}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="10">
                <Border Background="#1e293b" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="20" Width="280">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Yıllık Okuma Hedefi" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        <TextBlock Text="Bu yıl kaç kitap okumak istersin?" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <dxe:SpinEdit x:Name="SpinGoal" Value="24" MinValue="1" MaxValue="1000" IsFloatValue="False" 
                                      Height="40" Margin="0,0,0,15" Mask="d" 
                                      Background="#111722" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalContentAlignment="Center"/>

                        <dx:SimpleButton Content="Kaydet" Height="36" Background="#3b82f6" Foreground="White" FontWeight="Bold" 
                                         CornerRadius="8" Cursor="Hand" Click="BtnSaveGoal_Click"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </ScrollViewer>
</UserControl>
