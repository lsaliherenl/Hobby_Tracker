<UserControl x:Class="HobbyTracker.Views.Dashboard.DashboardSinemaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             mc:Ignorable="d" 
             d:DesignHeight="950" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Sayfa Yüklenme Animasyonu -->
        <Storyboard x:Key="SlideUpFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Hover Efekti için Stil -->
        <Style x:Key="StatsCardHoverStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SlideUpFadeIn}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="RootGrid" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. İSTATİSTİKLER -->
            <Grid Grid.Row="0" Margin="0,5,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Filmler -->
                <Border Grid.Column="0" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#ef4444" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#ef4444" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🎬" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="Filmler" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TotalMoviesText" Text="0" Foreground="#ef4444" FontSize="28" FontWeight="Bold"/>
                        <TextBlock x:Name="MovieCompletionText" Text="0 tamamlandı (%0)" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Diziler -->
                <Border Grid.Column="1" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#dc2626" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#dc2626" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📺" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="Diziler" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TotalSeriesText" Text="0" Foreground="#dc2626" FontSize="28" FontWeight="Bold"/>
                        <TextBlock x:Name="SeriesCompletionText" Text="0 tamamlandı (%0)" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Toplam Süre -->
                <Border Grid.Column="2" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#f87171" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#f87171" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⏱️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="Toplam Süre" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TotalWatchTimeText" Text="0" Foreground="#f87171" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text=" saat" Foreground="#f87171" FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <TextBlock x:Name="WatchTimeBreakdownText" Text="0s film, 0s dizi" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Devam Eden -->
                <Border Grid.Column="3" CornerRadius="10" Padding="15" Margin="0,0,10,0" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#3b82f6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#3b82f6" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="▶️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="Devam Eden" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="InProgressCountText" Text="0" Foreground="#3b82f6" FontSize="28" FontWeight="Bold"/>
                        <TextBlock x:Name="InProgressBreakdownText" Text="0 film, 0 dizi" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ort. Puan -->
                <Border Grid.Column="4" CornerRadius="10" Padding="15" Style="{StaticResource StatsCardHoverStyle}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#0f1425" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#fbbf24" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#fbbf24" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⭐" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="Ort. Puan" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="AvgRatingText" Text="0.0" Foreground="#fbbf24" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="/10" Foreground="#fbbf24" FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,4" Opacity="0.7"/>
                        </StackPanel>
                        <TextBlock x:Name="RatingCountText" Text="0 değerlendirme" Foreground="#64748b" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 2. SON EKLENENLER & VAKİT SAVAŞI -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Vakit Savaşı (SAĞ) -->
                <Border Grid.Column="2" CornerRadius="16" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.502"/>
                            <GradientStop Color="#FF3D141A" Offset="0.987"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#334155" Offset="0"/>
                            <GradientStop Color="#ef4444" Offset="0.5"/>
                            <GradientStop Color="#dc2626" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect Color="#ef4444" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>
                    
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="⚔️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#ef4444"/>
                            <StackPanel>
                                <TextBlock Text="Vakit Savaşı" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Film vs. Dizileme Süresi (Bu Yıl)" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                            <TextBlock x:Name="TotalWatchHoursText" Text="0" Foreground="White" FontSize="46" FontWeight="Bold"/>
                            <TextBlock Text=" saat toplam izleme" Foreground="#94a3b8" FontSize="14" VerticalAlignment="Bottom" Margin="6,0,0,10"/>
                        </StackPanel>

                        <!-- Progress Bar -->
                        <Grid Height="35" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="MovieProgressColumn" Width="50*"/>
                                <ColumnDefinition x:Name="SeriesProgressColumn" Width="50*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#f87171" CornerRadius="6,0,0,6">
                                <TextBlock x:Name="MoviePercentText" Text="50%" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#dc2626" CornerRadius="0,6,6,0">
                                <TextBlock x:Name="SeriesPercentText" Text="50%" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#f87171" Margin="0,0,6,0"/>
                            <TextBlock x:Name="MovieHoursText" Text="Filmler (0sa)" Foreground="#94a3b8" FontSize="12" Margin="0,0,20,0"/>
                            <Ellipse Width="10" Height="10" Fill="#dc2626" Margin="0,0,6,0"/>
                            <TextBlock x:Name="SeriesHoursText" Text="Diziler (0sa)" Foreground="#94a3b8" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Son Eklenenler (SOL) - Oyunlar Stili -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Grid Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Son Eklenenler" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Tümünü Gör Butonu -->
                    </Grid>

                    <ItemsControl x:Name="RecentItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Kart Tasarımı (Kitaplar Stili) -->
                                <Border Width="175" Margin="0,0,15,0" Padding="0" Background="#1e293b" CornerRadius="12" Cursor="Hand"
                                        MouseLeftButtonUp="RecentItem_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Kapak Resmi -->
                                        <Border Grid.Row="0" Height="240" CornerRadius="12,12,0,0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding PosterUrl}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                            
                                            <!-- Tür Badge -->
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"
                                                    Background="#ef4444" CornerRadius="4" Padding="6,3">
                                                <TextBlock Text="{Binding TypeDisplay}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Border>

                                        <!-- Başlık ve Bilgi -->
                                        <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" 
                                                       TextTrimming="CharacterEllipsis" FontSize="13" Margin="0,0,0,4"/>
                                            
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📅" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Year}" Foreground="#94a3b8" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Boş Durum -->
                    <Border x:Name="EmptyRecentState" Padding="40" Visibility="Collapsed" Background="#1e293b" CornerRadius="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🎬" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Henüz içerik eklenmemiş" Foreground="#94a3b8" FontSize="14" 
                                       Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 3. AYLIK İZLEME & FAVORİ YÖNETMENLER -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- On Yıl Analizi (SOL) -->
                <Border Grid.Column="0" CornerRadius="16" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#FF3D141A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#303b5c" Offset="0"/>
                            <GradientStop Color="#1e2847" Offset="0.5"/>
                            <GradientStop Color="#ef4444" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect Color="#ef4444" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="📈" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#ef4444"/>
                            <TextBlock Text="Aylık İzleme Süresi" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            <Border Background="#334155" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Son 6 Ay" Foreground="#94a3b8" FontSize="9"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
                            <StackPanel Margin="0,0,30,0">
                                <TextBlock Text="TOPLAM" Foreground="#64748b" FontSize="9" FontWeight="Bold"/>
                                <TextBlock x:Name="MonthlyTotalHoursText" Text="0 saat" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="ORTALAMA" Foreground="#64748b" FontSize="9" FontWeight="Bold"/>
                                <TextBlock x:Name="MonthlyAvgHoursText" Text="0 /ay" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Line Chart -->
                        <dxc:ChartControl x:Name="MonthlyWatchChart" Grid.Row="2" Height="200" 
                                          Background="Transparent" BorderThickness="0" BorderBrush="{x:Null}">
                            <dxc:XYDiagram2D>
                                <dxc:XYDiagram2D.DefaultPane>
                                    <dxc:Pane DomainBrush="Transparent" DomainBorderBrush="{x:Null}"/>
                                </dxc:XYDiagram2D.DefaultPane>
                                <dxc:XYDiagram2D.AxisX>
                                    <dxc:AxisX2D GridLinesVisible="False" Interlaced="False">
                                        <dxc:AxisX2D.Label>
                                            <dxc:AxisLabel Foreground="#94a3b8" FontSize="10"/>
                                        </dxc:AxisX2D.Label>
                                    </dxc:AxisX2D>
                                </dxc:XYDiagram2D.AxisX>
                                <dxc:XYDiagram2D.AxisY>
                                    <dxc:AxisY2D GridLinesVisible="False" Interlaced="False" Visible="False"/>
                                </dxc:XYDiagram2D.AxisY>
                                <dxc:LineSeries2D x:Name="WatchTimeSeries" DisplayName="Saat" 
                                                  ArgumentDataMember="MonthName" ValueDataMember="Hours"
                                                  Brush="#ef4444" MarkerVisible="True" MarkerSize="10">
                                    <dxc:LineSeries2D.LineStyle>
                                        <dxc:LineStyle Thickness="2"/>
                                    </dxc:LineSeries2D.LineStyle>
                                </dxc:LineSeries2D>
                            </dxc:XYDiagram2D>
                        </dxc:ChartControl>
                    </Grid>
                </Border>

                <!-- Favori Yönetmenler -->
                <Border Grid.Column="2" CornerRadius="16" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#FF3D141A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#303b5c" Offset="0"/>
                            <GradientStop Color="#1e2847" Offset="0.5"/>
                            <GradientStop Color="#ef4444" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect Color="#ef4444" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎬" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#ef4444"/>
                                <TextBlock Text="Favori Yönetmenler" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>

                        <ItemsControl x:Name="FavoriteDirectorsControl" Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Avatar -->
                                        <Border Width="36" Height="36" CornerRadius="18" Background="#334155" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" 
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★" Foreground="#fbbf24" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding AvgRating, StringFormat=F1}" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding MovieCount}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                            <TextBlock Text="Film" Foreground="#64748b" FontSize="10" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <TextBlock x:Name="EmptyDirectorsText" Grid.Row="1" Text="Yeterli veri yok" Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 4. ON YIL ANALİZİ -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <Border CornerRadius="16" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1f35" Offset="0"/>
                            <GradientStop Color="#141a2e" Offset="0.5"/>
                            <GradientStop Color="#FF3D141A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#303b5c" Offset="0"/>
                            <GradientStop Color="#1e2847" Offset="0.5"/>
                            <GradientStop Color="#ef4444" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect Color="#ef4444" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="📅" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#ef4444"/>
                            <TextBlock Text="On Yıl Analizi" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Bar Chart for decades -->
                        <Grid Height="100">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 1990s -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border x:Name="Bar1990s" Width="60" Height="20" Background="#fbbf24" CornerRadius="4,4,0,0"/>
                                <TextBlock Text="1990s" Foreground="#94a3b8" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- 2000s -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border x:Name="Bar2000s" Width="60" Height="40" Background="#f87171" CornerRadius="4,4,0,0"/>
                                <TextBlock Text="2000s" Foreground="#94a3b8" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- 2010s -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border x:Name="Bar2010s" Width="60" Height="80" Background="#ef4444" CornerRadius="4,4,0,0"/>
                                <TextBlock Text="2010s" Foreground="#94a3b8" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- 2020s -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border x:Name="Bar2020s" Width="60" Height="60" Background="#dc2626" CornerRadius="4,4,0,0"/>
                                <TextBlock Text="2020s" Foreground="#94a3b8" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 5. FAVORİLER & EN UZUN -->
            <Grid Grid.Row="4" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SOL: Favori Filmler + En Uzun Film -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="280"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Favori Filmler Carousel -->
                    <Border Grid.Row="0" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="CurrentFavoriteMovie_Click">
                        <Border.Background>
                            <ImageBrush x:Name="FavoriteMovieBgBrush" Stretch="UniformToFill" Opacity="0.4"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <Border Background="#CC0f172a" CornerRadius="16"/>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Navigasyon Butonları -->
                                <Button Grid.RowSpan="3" x:Name="PrevMovieBtn" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="PrevMovie_Click">
                                    <TextBlock Text="❮" Foreground="White" FontSize="20" FontWeight="Bold" Opacity="0.7"/>
                                </Button>
                                <Button Grid.RowSpan="3" x:Name="NextMovieBtn" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="NextMovie_Click">
                                    <TextBlock Text="❯" Foreground="White" FontSize="20" FontWeight="Bold" Opacity="0.7"/>
                                </Button>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="❤️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#ef4444"/>
                                    <TextBlock Text="Favori Filmler" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Valid Data Container -->
                                <Grid x:Name="FavoriteMovieCard" Grid.Row="0" Grid.RowSpan="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Yıl Badge (Sağ Üst) -->
                                    <Border Grid.Row="0" HorizontalAlignment="Right" Background="#334155" CornerRadius="6" Padding="8,4">
                                        <TextBlock x:Name="FavoriteMovieYear" Text="2024" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>

                                    <!-- Film Bilgisi -->
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="15">
                                        <TextBlock x:Name="FavoriteMovieTitle" Text="Film Adı" Foreground="White" FontSize="24" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,5" TextAlignment="Center"/>
                                        <TextBlock x:Name="FavoriteMovieDirector" Text="Yönetmen" Foreground="#94a3b8" FontSize="13" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Alt İstatistikler -->
                                    <Grid Grid.Row="2" Margin="15,0,15,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="PUAN" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                                                <TextBlock x:Name="FavoriteMovieRating" Text="8.5" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Detaylar" Foreground="#ef4444" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="→" Foreground="#ef4444" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                
                                <!-- Empty State -->
                                <TextBlock x:Name="NoFavoriteMoviesText" Grid.Row="1" Text="Favori film yok" 
                                           Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- En Uzun Film -->
                    <Border Grid.Row="2" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="LongestMovie_Click">
                        <Border.Background>
                            <ImageBrush x:Name="LongestMovieBgBrush" Stretch="UniformToFill" Opacity="0.4"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <Border Background="#CC0f172a" CornerRadius="16"/>
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" HorizontalAlignment="Left" Background="#fbbf24" CornerRadius="6" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏆" FontSize="12" Margin="0,0,5,0"/>
                                            <TextBlock Text="En Uzun Film" Foreground="Black" FontSize="11" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" HorizontalAlignment="Right" Background="#334155" CornerRadius="6" Padding="8,4">
                                        <TextBlock x:Name="LongestMovieDuration" Text="180 dk" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>

                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,15">
                                        <TextBlock x:Name="LongestMovieTitle" Text="Film Adı" Foreground="White" FontSize="20" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                     </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="PUAN" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                                                <TextBlock x:Name="LongestMovieRating" Text="-" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Detayları Gör" Foreground="#ef4444" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="→" Foreground="#ef4444" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- SAĞ: Favori Diziler + En Uzun Dizi -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="280"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Favori Diziler Carousel -->
                    <Border Grid.Row="0" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="CurrentFavoriteSeries_Click">
                        <Border.Background>
                            <ImageBrush x:Name="FavoriteSeriesBgBrush" Stretch="UniformToFill" Opacity="0.4"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <Border Background="#CC0f172a" CornerRadius="16"/>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Navigasyon Butonları -->
                                <Button Grid.RowSpan="3" x:Name="PrevSeriesBtn" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="PrevSeries_Click">
                                    <TextBlock Text="❮" Foreground="White" FontSize="20" FontWeight="Bold" Opacity="0.7"/>
                                </Button>
                                <Button Grid.RowSpan="3" x:Name="NextSeriesBtn" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="NextSeries_Click">
                                    <TextBlock Text="❯" Foreground="White" FontSize="20" FontWeight="Bold" Opacity="0.7"/>
                                </Button>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="❤️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#ef4444"/>
                                    <TextBlock Text="Favori Diziler" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Valid Data Container -->
                                <Grid x:Name="FavoriteSeriesCard" Grid.Row="0" Grid.RowSpan="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Info Badge (Sağ Üst) -->
                                    <Border Grid.Row="0" HorizontalAlignment="Right" Background="#334155" CornerRadius="6" Padding="8,4">
                                        <TextBlock x:Name="FavoriteSeriesInfo" Text="5 Sezon" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>

                                    <!-- Dizi Bilgisi -->
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="15">
                                        <TextBlock x:Name="FavoriteSeriesTitle" Text="Dizi Adı" Foreground="White" FontSize="24" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,5" TextAlignment="Center"/>
                                        <TextBlock x:Name="FavoriteSeriesYears" Text="2010-2015" Foreground="#94a3b8" FontSize="13" TextAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Alt İstatistikler -->
                                    <Grid Grid.Row="2" Margin="15,0,15,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="PUAN" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                                                <TextBlock x:Name="FavoriteSeriesRating" Text="9.0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Detaylar" Foreground="#ef4444" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="→" Foreground="#ef4444" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                
                                <!-- Empty State -->
                                <TextBlock x:Name="NoFavoriteSeriesText" Grid.Row="1" Text="Favori dizi yok" 
                                           Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- En Uzun Dizi -->
                    <Border Grid.Row="2" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="LongestSeries_Click">
                        <Border.Background>
                            <ImageBrush x:Name="LongestSeriesBgBrush" Stretch="UniformToFill" Opacity="0.4"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <Border Background="#CC0f172a" CornerRadius="16"/>
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" HorizontalAlignment="Left" Background="#fbbf24" CornerRadius="6" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏆" FontSize="12" Margin="0,0,5,0"/>
                                            <TextBlock Text="En Uzun Dizi" Foreground="Black" FontSize="11" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" HorizontalAlignment="Right" Background="#334155" CornerRadius="6" Padding="8,4">
                                        <TextBlock x:Name="LongestSeriesInfo" Text="100 Bölüm" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>

                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,15">
                                        <TextBlock x:Name="LongestSeriesTitle" Text="Dizi Adı" Foreground="White" FontSize="20" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="PUAN" Foreground="#94a3b8" FontSize="9" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                                                <TextBlock x:Name="LongestSeriesRating" Text="-" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Detayları Gör" Foreground="#ef4444" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="→" Foreground="#ef4444" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
