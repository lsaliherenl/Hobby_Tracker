<UserControl x:Class="HobbyTracker.Views.EditMovieWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0F172A">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0F172A"/>
        <SolidColorBrush x:Key="CardDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#334155"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextGray" Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextWhite" Color="#F1F5F9"/>

        <!-- Genre Tag Style -->
        <Style x:Key="GenreTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,30,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="0,10">
                            <TextBlock x:Name="Text" Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="Text" Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="Text" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Progress Bar Style (Same as MoviesView) -->
        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="MaxHeight" Value="6"/>
            <Setter Property="Background" Value="#232f48"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" Height="6">
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3" Height="6"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3" Height="6">
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B82F6" BlurRadius="4" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ScrollBar Style (Same as MoviesView) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Backdrop Image with Blur Effect -->
        <Grid x:Name="BackdropContainer" Height="350" VerticalAlignment="Top">
            <Image x:Name="BackdropImage" Source="{Binding BackdropUrl}" Stretch="UniformToFill">
                <Image.Effect>
                    <BlurEffect Radius="30"/>
                </Image.Effect>
            </Image>
            <!-- Dark gradient overlay -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#80000000" Offset="0"/>
                        <GradientStop Color="#0F172A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Breadcrumb -->
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Tabs -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- 1. BREADCRUMB -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource CardDark}" 
                        Cursor="Hand" MouseLeftButtonUp="BtnBack_Click" Margin="0,0,15,0" VerticalAlignment="Center">
                    <TextBlock Text="←" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25"/>
                </Border>
                <TextBlock Text="Movies" Foreground="{StaticResource TextGray}" FontSize="13" Cursor="Hand" 
                           MouseLeftButtonUp="BtnBack_Click" VerticalAlignment="Center"/>
                <TextBlock Text=" / " Foreground="{StaticResource TextGray}" FontSize="13" Margin="8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="BreadcrumbTitle" Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 2. HEADER -->
            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Poster -->
                    <ColumnDefinition Width="*"/>    <!-- Info -->
                </Grid.ColumnDefinitions>

                <!-- Movie Poster -->
                <Border Grid.Column="0" Width="180" Height="270" CornerRadius="12" Margin="0,0,30,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <Border.Background>
                        <ImageBrush x:Name="PosterImage" ImageSource="{Binding PosterUrl}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>

                <!-- Movie Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Title -->
                    <TextBlock x:Name="TxtTitle" Text="{Binding Title}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                    <!-- Meta Info: Year, Rating, Duration, Director -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtYear" Text="{Binding Year}" Foreground="{StaticResource TextGray}" FontSize="14" VerticalAlignment="Center"/>
                        
                        <TextBlock Text="  •  " Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                        <Border Background="#374151" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtMpaa" Text="{Binding MpaaRating}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        
                        <TextBlock Text="  •  " Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                        <TextBlock x:Name="TxtDuration" Text="{Binding DurationFormatted}" Foreground="{StaticResource TextGray}" FontSize="14" VerticalAlignment="Center"/>
                        
                        <TextBlock Text="  •  " Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                        <TextBlock x:Name="TxtDirector" Text="{Binding Director}" Foreground="{StaticResource TextGray}" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        
                        <!-- TMDB Rating (Yellow) -->
                        <Border Background="{StaticResource CardDark}" CornerRadius="18" Padding="12,0" Height="36" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="★" Foreground="#fbbf24" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtTmdbRating" Text="{Binding GlobalRating, StringFormat='{}{0:0.0}'}" Foreground="#fbbf24" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="/10" Foreground="{StaticResource TextGray}" FontSize="11" Margin="2,0,0,2" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>

                        <!-- Star Rating with Popup -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <!-- Star Popup -->
                            <Popup x:Name="StarPopup"
                                   PlacementTarget="{Binding ElementName=BtnStarSelect}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   VerticalOffset="6">
                                <Border Background="{StaticResource CardDark}" CornerRadius="10" Padding="12" 
                                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal" x:Name="StarContainer">
                                        <!-- Stars will be created dynamically in code-behind -->
                                    </StackPanel>
                                </Border>
                            </Popup>
                            
                            <!-- Star Select Button -->
                            <Border x:Name="BtnStarSelect" Height="36" CornerRadius="18" Background="{StaticResource CardDark}" 
                                    Padding="12,0" Cursor="Hand" MouseLeftButtonUp="BtnStarSelect_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#374151"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="★" Foreground="#fbbf24" FontSize="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtStarRating" Text="0/10" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Status Dropdown -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                            <!-- Status Popup -->
                            <Popup x:Name="StatusPopup"
                                   PlacementTarget="{Binding ElementName=BtnStatusSelect}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   VerticalOffset="6">
                                <Border Background="{StaticResource CardDark}" CornerRadius="10" Padding="8" 
                                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Width="160">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <Border x:Name="StatusIzlendi" Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                MouseLeftButtonUp="StatusOption_Click" Tag="Completed">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#374151"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="İzlendi" Foreground="White" FontSize="13"/>
                                        </Border>
                                        <Border Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                MouseLeftButtonUp="StatusOption_Click" Tag="InProgress">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#374151"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="İzleniyor" Foreground="White" FontSize="13"/>
                                        </Border>
                                        <Border Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                MouseLeftButtonUp="StatusOption_Click" Tag="PlanToWatch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#374151"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Listem" Foreground="White" FontSize="13"/>
                                        </Border>
                                        <Border Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                MouseLeftButtonUp="StatusOption_Click" Tag="Dropped">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#374151"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Yarım Bırakıldı" Foreground="White" FontSize="13"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            
                            <!-- Status Button -->
                            <Border x:Name="BtnStatusSelect" Height="36" CornerRadius="18" 
                                    Background="{StaticResource PrimaryBlue}" Padding="20,0"
                                    Cursor="Hand" MouseLeftButtonUp="BtnStatusSelect_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtStatusDisplay" Text="İzlendi" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text=" ▼" Foreground="White" FontSize="10" VerticalAlignment="Center" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Favorite Button -->
                        <Border x:Name="BtnFavorite" Width="36" Height="36" CornerRadius="18" Background="#374151" 
                                Cursor="Hand" MouseLeftButtonUp="BtnFavorite_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4B5563"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock x:Name="TxtFavoriteIcon" Text="🤍" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Genre Tags -->
                    <ItemsControl x:Name="GenresList" ItemsSource="{Binding Genres}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GenreTagStyle}">
                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <!-- 3. TABS -->
            <Border Grid.Row="2" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,0,0,25">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TabOverview" Content="Genel Bakış" IsChecked="True" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked"/>
                    <RadioButton x:Name="TabCast" Content="Oyuncular" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked"/>
                    <RadioButton x:Name="TabNotes" Content="Kişisel Notlar" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked"/>
                </StackPanel>
            </Border>

            <!-- 4. CONTENT AREA -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>      <!-- Main Content -->
                    <ColumnDefinition Width="320"/>   <!-- Sidebar -->
                </Grid.ColumnDefinitions>

                <!-- LEFT: Main Content -->
                <StackPanel Grid.Column="0" Margin="0,0,30,0">

                    <!-- Overview Tab Content -->
                    <StackPanel x:Name="OverviewContent">
                        <!-- Özet -->
                        <TextBlock Text="Özet" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                        <TextBlock x:Name="TxtSynopsis" Text="{Binding Synopsis}" FontSize="14" Foreground="{StaticResource TextGray}" 
                                   TextWrapping="Wrap" LineHeight="24" Margin="0,0,0,30"/>

                        <!-- Personal Notes Card -->
                        <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20" Margin="0,0,0,30">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Kişisel Notlar" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Hand" MouseLeftButtonUp="BtnEditNotes_Click">
                                        <TextBlock Text="✏️" FontSize="12" Margin="0,0,5,0"/>
                                        <TextBlock Text="Düzenle" Foreground="{StaticResource PrimaryBlue}" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock x:Name="TxtPersonalNote" Text="{Binding PersonalNote}" FontSize="13" Foreground="{StaticResource TextGray}" 
                                           FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                <!-- User Tags -->
                                <ItemsControl x:Name="UserTagsList" ItemsSource="{Binding UserTags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#3B82F6" CornerRadius="12" Padding="12,6" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Başrol Oyuncuları -->
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Başrol Oyuncuları" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Tümünü gör" Foreground="{StaticResource PrimaryBlue}" FontSize="13" HorizontalAlignment="Right" 
                                       Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="BtnSeeAllCast_Click"/>
                        </Grid>

                        <ItemsControl x:Name="CastList" ItemsSource="{Binding Cast}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="90" Margin="0,0,20,0">
                                        <Border Width="70" Height="70" CornerRadius="35" Margin="0,0,0,10">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" FontWeight="SemiBold" 
                                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Character}" Foreground="{StaticResource TextGray}" FontSize="10" 
                                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Oyuncular Sekmesi İçeriği -->
                    <StackPanel x:Name="CastContent" Visibility="Collapsed">
                        <TextBlock Text="Oyuncular" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                        
                        <!-- Full Cast Grid -->
                        <ItemsControl x:Name="FullCastList" ItemsSource="{Binding Cast}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12" Margin="0,0,15,15" Width="180">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="50" Height="50" CornerRadius="25" Margin="0,0,12,0">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" Width="100">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" FontWeight="SemiBold" 
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Character}" Foreground="{StaticResource TextGray}" FontSize="11" 
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Notlar Sekmesi İçeriği -->
                    <StackPanel x:Name="NotesContent" Visibility="Collapsed">
                        <TextBlock Text="Kişisel Notlar" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                        
                        <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBox x:Name="TxtNotesEditor" 
                                         Text="{Binding PersonalNote, Mode=TwoWay}" 
                                         Background="#1E293B" Foreground="White" 
                                         BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                         Padding="15" FontSize="14" 
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         MinHeight="200" MaxHeight="400"
                                         VerticalScrollBarVisibility="Auto"/>
                                
                                <dx:SimpleButton Content="Notları Kaydet" Height="40" Margin="0,15,0,0"
                                                 Background="{StaticResource PrimaryBlue}" Foreground="White" 
                                                 CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                 Click="BtnSaveNotes_Click"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- User Tags Section -->
                        <TextBlock Text="Etiketler" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,30,0,15"/>
                        <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <!-- Existing Tags -->
                                <ItemsControl x:Name="TagsItemControl" ItemsSource="{Binding UserTags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#3B82F6" CornerRadius="12" Padding="10,6" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" ✕" Foreground="#FFFFFF" FontSize="12" Cursor="Hand" VerticalAlignment="Center"
                                                               MouseLeftButtonUp="BtnRemoveTag_Click" Tag="{Binding}" Opacity="0.7"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <!-- Add New Tag Input -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox x:Name="TxtNewTag" Grid.Column="0"
                                             Background="#1E293B" Foreground="White" 
                                             BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                             Padding="12,10" FontSize="13" 
                                             VerticalContentAlignment="Center"
                                             KeyDown="TxtNewTag_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Tag" Value="Yeni etiket ekle..."/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    
                                    <dx:SimpleButton Grid.Column="1" Content="Ekle" Width="80" Height="38" Margin="10,0,0,0"
                                                     Background="{StaticResource PrimaryBlue}" Foreground="White" 
                                                     CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                     Click="BtnAddTag_Click"/>
                                </Grid>
                                
                                <TextBlock Text="İpucu: Virgülle ayırarak birden fazla etiket ekleyebilirsiniz" 
                                           Foreground="{StaticResource TextGray}" FontSize="11" Margin="0,10,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT: Sidebar -->
                <StackPanel Grid.Column="1">
                    <!-- Watching Progress Card -->
                    <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="İzleme İlerlemesi" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="TxtProgressPercent" HorizontalAlignment="Right" FontSize="14" FontWeight="Bold" Foreground="#10B981">
                                    <Run Text="{Binding ProgressPercentage, StringFormat={}{0:0}, Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>

                            <ProgressBar x:Name="ProgressBar" Value="{Binding ProgressPercentage, Mode=OneWay}" Maximum="100" 
                                         Style="{StaticResource ModernProgressBarStyle}" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,20">
                                <TextBlock x:Name="TxtWatched" Text="{Binding WatchedFormatted}" Foreground="{StaticResource TextGray}" FontSize="12"/>
                                <TextBlock x:Name="TxtRemaining" Text="{Binding RemainingFormatted}" Foreground="{StaticResource TextGray}" FontSize="12" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Progress Update Popup -->
                            <Popup x:Name="ProgressPopup"
                                   PlacementTarget="{Binding ElementName=BtnUpdateProgress}"
                                   Placement="Top"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   VerticalOffset="-10">
                                <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20" Width="280"
                                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="İlerleme Güncelle" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                                        
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="İzlenen Süre" Foreground="{StaticResource TextGray}" FontSize="12"/>
                                            <TextBlock x:Name="PopupProgressText" HorizontalAlignment="Right" Foreground="#10B981" FontSize="12" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Value="0" 
                                                Height="20" Margin="0,0,0,15"
                                                ValueChanged="ProgressSlider_ValueChanged"/>
                                        
                                        <Grid Margin="0,0,0,15">
                                            <TextBlock x:Name="PopupWatchedText" Foreground="{StaticResource TextGray}" FontSize="11"/>
                                            <TextBlock x:Name="PopupTotalText" HorizontalAlignment="Right" Foreground="{StaticResource TextGray}" FontSize="11"/>
                                        </Grid>
                                        
                                        <dx:SimpleButton Content="Kaydet" Height="36" 
                                                         Background="{StaticResource PrimaryBlue}" Foreground="White" 
                                                         CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                         Click="BtnSaveProgress_Click"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            
                            <dx:SimpleButton x:Name="BtnUpdateProgress" Content="İlerleme Güncelle" Height="40" 
                                             Background="Transparent" Foreground="White" 
                                             BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                             CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                             Click="BtnUpdateProgress_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Movie Info Card -->
                    <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="DURUM" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="Yayınlandı" Foreground="White" FontSize="14"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="ORİJİNAL DİL" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtLanguage" Text="{Binding OriginalLanguage}" Foreground="White" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Delete Movie Button -->
                    <dx:SimpleButton Content="🗑️ Filmi Sil" Height="40" Margin="0,20,0,0"
                                     Background="#991B1B" Foreground="White" 
                                     CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                     Click="BtnDeleteMovie_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
    
    <!-- Custom Delete Confirmation Popup -->
    <Grid x:Name="DeletePopupOverlay" Visibility="Collapsed">
        <Border Background="#000000" Opacity="0.7"/>
        <Border Background="{StaticResource SurfaceDark}" CornerRadius="16" 
                Width="400" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
            </Border.Effect>
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="⚠️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Filmi Sil" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Message -->
                <TextBlock Grid.Row="1" x:Name="TxtDeleteMessage" 
                           Text="Bu filmi silmek istediğinize emin misiniz?" 
                           Foreground="{StaticResource TextGray}" FontSize="14" TextWrapping="Wrap" 
                           VerticalAlignment="Center"/>
                
                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <dx:SimpleButton Content="İptal" Width="100" Height="38" Margin="0,0,10,0"
                                     Background="Transparent" Foreground="White" 
                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                     CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                     Click="BtnCancelDelete_Click"/>
                    <dx:SimpleButton Content="Sil" Width="100" Height="38" 
                                     Background="#DC2626" Foreground="White" 
                                     CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                     Click="BtnConfirmDelete_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </Grid>
</UserControl>
