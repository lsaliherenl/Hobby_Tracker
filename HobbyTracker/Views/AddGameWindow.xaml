<Window x:Class="HobbyTracker.Views.AddGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        
        Title="Oyun Ekle" 
        Icon="/HT.ico"
        WindowState="Maximized" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Window.Resources>
        <!-- Renk Paletleri -->
        <SolidColorBrush x:Key="BgDark" Color="#FF0C111A"/>
        <SolidColorBrush x:Key="CardDark" Color="#1a2230"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextLight" Color="#92a4c9"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2a3447"/>
        <SolidColorBrush x:Key="BorderColor" Color="#232f48"/>
        <SolidColorBrush x:Key="PanelDark" Color="#1a2230"/>
        <SolidColorBrush x:Key="TextGray" Color="#92a4c9"/>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748B"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="20,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#ef4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Item Style -->
        <Style x:Key="DarkComboItemStyle" TargetType="dxe:ComboBoxEditItem">
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#111722"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2b6cee"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1a2230"/>
                    <Setter Property="Foreground" Value="#2b6cee"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Ekranı Karart: Arka plan overlay -->
    <Grid>
        <Border Background="#99000000" MouseDown="Background_MouseDown"/>

        <!-- Ana İçerik Penceresi -->
        <Border x:Name="MainBorder" Width="950" Height="680" Background="#FF0C111A" CornerRadius="16" 
                BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="10" Opacity="0.7"/>
            </Border.Effect>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Search Bar -->
                    <RowDefinition Height="*"/>    <!-- Content (Split View) -->
                </Grid.RowDefinitions>

                <!-- 1. HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🎮" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Oyun Ekle" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource CloseButtonStyle}" Click="BtnClose_Click">
                        <TextBlock Text="✕" Foreground="{StaticResource TextLight}" FontSize="16"/>
                    </Button>
                </Grid>

                <!-- 2. SEARCH BAR -->
                <Grid Grid.Row="1" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Input -->
                    <Border Background="{StaticResource CardDark}" CornerRadius="10" Height="45" BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/ZImages/search_png.png" Width="18" Height="18" Margin="15,0,5,0" VerticalAlignment="Center" Opacity="0.5"/>
                            <TextBox x:Name="TxtSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                     Foreground="White" FontSize="14" VerticalContentAlignment="Center"
                                     Margin="5,0,10,0" KeyDown="TxtSearch_KeyDown">
                                <TextBox.Resources>
                                    <Style TargetType="{x:Type TextBox}">
                                        <Setter Property="CaretBrush" Value="White"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            
                            <!-- Placeholder -->
                            <TextBlock Grid.Column="1" Text="Oyun adı girin (örn: Witcher, Cyberpunk)..." IsHitTestVisible="False"
                                       Foreground="{StaticResource TextLight}" FontSize="14" VerticalAlignment="Center" Margin="7,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Search Button -->
                    <Button x:Name="BtnSearch" Grid.Column="1" Content="Ara" Width="80" Height="45"
                            Style="{StaticResource PrimaryButtonStyle}" 
                            Margin="10,0,0,0" Click="BtnSearch_Click"/>
                </Grid>

                <!-- 3. CONTENT AREA -->
                <Grid Grid.Row="2">
                    
                    <!-- EMPTY STATE (Arama yapılmadan önce gösterilir) -->
                    <Grid x:Name="EmptyStatePanel" Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-50,0,0">
                            
                            <!-- Büyük İkon -->
                            <Border Width="100" Height="100" CornerRadius="50" Background="#1F2937" Margin="0,0,0,25">
                                <TextBlock Text="🎮" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                            </Border>
                            
                            <!-- Başlık -->
                            <TextBlock Text="Oyun Aramaya Başlayın" FontSize="22" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            
                            <!-- Açıklama -->
                            <TextBlock Text="Yukarıdaki arama kutusunu kullanarak oynamak istediğiniz oyunu bulun." 
                                       Foreground="#9CA3AF" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" 
                                       MaxWidth="400" TextAlignment="Center" Margin="0,0,0,30"/>
                            
                            <!-- Öneri Kutucukları -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12,8" Margin="5,0" Cursor="Hand"
                                        BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                    <TextBlock Text="🔥 Popüler Oyunlar" Foreground="{StaticResource TextLight}" FontSize="12"/>
                                </Border>
                                <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12,8" Margin="5,0" Cursor="Hand"
                                        BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                    <TextBlock Text="⭐ En Çok Puanlı" Foreground="{StaticResource TextLight}" FontSize="12"/>
                                </Border>
                                <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12,8" Margin="5,0" Cursor="Hand"
                                        BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                    <TextBlock Text="🎮 Yeni Çıkanlar" Foreground="{StaticResource TextLight}" FontSize="12"/>
                                </Border>
                            </StackPanel>
                            
                        </StackPanel>
                    </Grid>
                    
                    <!-- SEARCH RESULTS PANEL (Arama yapıldıktan sonra gösterilir) -->
                    <Grid x:Name="SearchResultsPanel" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/> <!-- Sol Panel: Liste -->
                            <ColumnDefinition Width="20"/>  <!-- Boşluk -->
                            <ColumnDefinition Width="*"/>   <!-- Sağ Panel: Detay -->
                        </Grid.ColumnDefinitions>

                        <!-- LEFT PANEL: Search Results -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="ARAMA SONUÇLARI" Foreground="{StaticResource TextLight}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Border Grid.Row="1" Background="{StaticResource CardDark}" CornerRadius="12" ClipToBounds="True"
                                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                <ListBox x:Name="LstGames" Background="Transparent" BorderThickness="0" 
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         SelectionChanged="LstGames_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Border" Padding="10" Margin="0,0,0,2" CornerRadius="8" Background="Transparent" Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource CardDark}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Border" Property="Background" Value="#1E3A5A"/>
                                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                                <Setter TargetName="Border" Property="BorderThickness" Value="1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Game Thumbnail -->
                                                <Border CornerRadius="4" Height="75" Width="50">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding BackgroundImage}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>

                                                <!-- Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding Released}" Foreground="#9CA3AF" FontSize="12"/>
                                                        <TextBlock Text=" • " Foreground="#6B7280" FontSize="12"/>
                                                        <TextBlock Text="{Binding Rating10, StringFormat={}{0:F1}}" Foreground="#fbbf24" FontSize="12"/>
                                                        <TextBlock Text="★" Foreground="#fbbf24" FontSize="12" Margin="2,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <!-- Arrow Icon -->
                                                <TextBlock Grid.Column="2" Text="›" Foreground="#60A5FA" FontSize="20" 
                                                           VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            
                            <!-- Loading Indicator -->
                            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Height="2" VerticalAlignment="Top" 
                                         Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Visibility="Collapsed"/>
                        </Grid>

                        <!-- RIGHT PANEL: Details & Form -->
                        <Grid Grid.Column="2" x:Name="DetailPanel" Visibility="Hidden">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Top Details -->
                                <RowDefinition Height="*"/>    <!-- Form Fields -->
                                <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                            </Grid.RowDefinitions>

                            <!-- Top Details -->
                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Game Poster -->
                                <Border CornerRadius="10" Height="160" Width="120" BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                    <Border.Background>
                                        <ImageBrush x:Name="ImgPoster" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <!-- Game Info -->
                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">
                                    <TextBlock x:Name="TxtTitle" Text="Oyun Seçin" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                    
                                    <!-- Genres Panel -->
                                    <StackPanel x:Name="GenresPanel" Orientation="Horizontal" Margin="0,8,0,0">
                                        <Border Background="{StaticResource CardDark}" CornerRadius="6" Padding="8,4" Margin="0,0,6,0"
                                                BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                            <TextBlock x:Name="TxtGenre1" Text="Tür 1" Foreground="{StaticResource TextLight}" FontSize="11"/>
                                        </Border>
                                        <Border Background="{StaticResource CardDark}" CornerRadius="6" Padding="8,4" Margin="0,0,6,0"
                                                BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                            <TextBlock x:Name="TxtGenre2" Text="Tür 2" Foreground="{StaticResource TextLight}" FontSize="11"/>
                                        </Border>
                                        <Border Background="{StaticResource CardDark}" CornerRadius="6" Padding="8,4"
                                                BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                            <TextBlock x:Name="TxtGenre3" Text="Tür 3" Foreground="{StaticResource TextLight}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock x:Name="TxtDescription" Text="Bir oyun seçerek detayları görüntüleyin."
                                               Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap" 
                                               MaxHeight="60" TextTrimming="CharacterEllipsis"
                                               Margin="0,10,0,0" LineHeight="18"/>
                                </StackPanel>
                            </Grid>

                            <!-- Form Fields -->
                            <Border Grid.Row="1" Background="{StaticResource CardDark}" CornerRadius="12" 
                                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Kütüphaneye Ekle" Foreground="White" FontWeight="Bold" FontSize="15" Margin="0,0,0,15"/>

                                    <!-- Status and Platform Side by Side -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="DURUM" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <Border Height="40" CornerRadius="8" Background="#111722" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                                <dxe:ComboBoxEdit x:Name="CmbStatus" 
                                                                  ShowBorder="False"
                                                                  Background="Transparent" 
                                                                  Foreground="White" 
                                                                  FontSize="13"
                                                                  Padding="8,0"
                                                                  IsTextEditable="False" 
                                                                  AllowDefaultButton="False"
                                                                  ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                                                  VerticalContentAlignment="Center">
                                                    <dxe:ComboBoxEditItem Content="Oynuyor"/>
                                                    <dxe:ComboBoxEditItem Content="Tamamlandı"/>
                                                    <dxe:ComboBoxEditItem Content="İstek Listesi"/>
                                                    <dxe:ComboBoxEditItem Content="Bırakıldı"/>
                                                </dxe:ComboBoxEdit>
                                            </Border>
                                        </StackPanel>

                                        <!-- Platform -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="PLATFORM" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <Border Height="40" CornerRadius="8" Background="#111722" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                                <dxe:ComboBoxEdit x:Name="CmbPlatform" 
                                                                  ShowBorder="False"
                                                                  Background="Transparent" 
                                                                  Foreground="White" 
                                                                  FontSize="13"
                                                                  Padding="8,0"
                                                                  IsTextEditable="False"
                                                                  AllowDefaultButton="False"
                                                                  ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                                                  VerticalContentAlignment="Center">
                                                    <dxe:ComboBoxEditItem Content="PC (Steam)"/>
                                                    <dxe:ComboBoxEditItem Content="PlayStation 5"/>
                                                    <dxe:ComboBoxEditItem Content="Xbox Series X"/>
                                                    <dxe:ComboBoxEditItem Content="Nintendo Switch"/>
                                                    <dxe:ComboBoxEditItem Content="Mobil"/>
                                                </dxe:ComboBoxEdit>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Rating with Star Popup -->
                                    <TextBlock Text="PUANIM" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                    
                                    <!-- Star Popup -->
                                    <Popup x:Name="StarPopup"
                                           PlacementTarget="{Binding ElementName=BtnStarSelect}"
                                           Placement="Bottom"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade"
                                           VerticalOffset="5">
                                        <Border Background="{StaticResource CardDark}" CornerRadius="10" Padding="12" 
                                                BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" x:Name="StarContainer">
                                                <!-- Stars will be created dynamically in code-behind -->
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                    
                                    <!-- Star Select Button -->
                                    <Border x:Name="BtnStarSelect" Height="40" CornerRadius="8" Background="#111722" 
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                            Cursor="Hand" MouseLeftButtonUp="BtnStarSelect_MouseUp">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtStarRating" Text="0/10" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Action Button -->
                            <Button x:Name="BtnSave" Grid.Row="2" Height="50" Margin="0,15,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}" Click="BtnSave_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="18" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="Kütüphaneye Ekle" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Empty Detail State (Oyun seçilmeden önce) -->
                        <Grid x:Name="EmptyDetailPanel" Grid.Column="2" Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="👈" FontSize="40" HorizontalAlignment="Center" Opacity="0.5"/>
                                <TextBlock Text="Listeden bir oyun seçin" Foreground="#6B7280" FontSize="14" 
                                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>