<UserControl x:Class="HobbyTracker.Views.GamesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:HobbyTracker.Views"
             xmlns:converters="clr-namespace:HobbyTracker.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1400">

    <UserControl.Resources>
        <Storyboard x:Key="SlideUpFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <SolidColorBrush x:Key="BgDark" Color="#FF0C111A"/>
        <SolidColorBrush x:Key="CardDark" Color="#1a2230"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#161d2a"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2b6cee"/>
        <SolidColorBrush x:Key="TextLight" Color="#92a4c9"/>
        <SolidColorBrush x:Key="TextGray" Color="#92a4c9"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2a3447"/>
        <SolidColorBrush x:Key="BorderColor" Color="#232f48"/>

        <converters:PlayTimeConverter x:Key="PlayTimeConverter"/>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Filter Tab Style -->
        <Style x:Key="ModernFilterTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <TextBlock x:Name="Text" Text="{TemplateBinding Content}" 
                                       Foreground="{TemplateBinding Foreground}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0"/>
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="GameCardTemplate">
            <Border Width="340" Height="220" Margin="0,0,20,20" CornerRadius="16" 
                    Background="{StaticResource CardDark}" 
                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                    Cursor="Hand"
                    PreviewMouseLeftButtonDown="GameCard_PreviewMouseLeftButtonDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform X="0"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#2b6cee" BlurRadius="15" ShadowDepth="5" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="-5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Seçim Checkbox -->
                    <CheckBox x:Name="GameCheckBox" HorizontalAlignment="Left" VerticalAlignment="Top" 
                              Margin="10" Visibility="Collapsed" 
                              Checked="GameCheckBox_Checked" Unchecked="GameCheckBox_Unchecked"
                              Click="GameCheckBox_Click" Panel.ZIndex="10"/>

                    <!-- Görsel - Tüm kartı kaplar -->
                    <!-- Görsel - Tüm kartı kaplar -->
                    <!-- Görsel - Tüm kartı kaplar -->
                    <Border Grid.Row="0" CornerRadius="16" Background="#0f172a">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}" 
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}" 
                                            CornerRadius="16" Background="Black"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image x:Name="GameCoverImage" Stretch="UniformToFill" Opacity="0.9" 
                               ImageFailed="GameImage_ImageFailed" Loaded="GameImage_Loaded"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Gradient Overlay - Alt kısımda karartma efekti -->
                    <Border Grid.Row="0" VerticalAlignment="Bottom" Height="100" CornerRadius="0,0,16,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#001a2230" Offset="0"/>
                                <GradientStop Color="#CC1a2230" Offset="0.5"/>
                                <GradientStop Color="#FF1a2230" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Status Badge - Sağ üst köşe -->
                    <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" 
                            CornerRadius="10" Padding="8,3" BorderBrush="#30FFFFFF" BorderThickness="1" Panel.ZIndex="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Oynuyor">
                                        <Setter Property="Background" Value="#FF146CAF"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Tamamlandı">
                                        <Setter Property="Background" Value="#E6ef4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Bırakıldı">
                                        <Setter Property="Background" Value="#E694a3b8"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="İstek Listesi">
                                        <Setter Property="Background" Value="#FF295E12"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Background" Value="#E6fbbf24"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Foreground="White" FontSize="9" FontWeight="Bold">
                            <TextBlock.Text>
                                <Binding Path="Status">
                                    <Binding.FallbackValue>Oynuyor</Binding.FallbackValue>
                                </Binding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>

                    <!-- Rating Badge - Sağ alt köşe -->
                    <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" 
                            Background="#99000000" CornerRadius="6" Padding="6,2" Panel.ZIndex="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="11" Margin="0,0,3,0"/>
                            <TextBlock Foreground="White" FontSize="10" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1}">
                                        <Binding Path="UserRating" FallbackValue="0"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Bilgiler - Alt kısımda overlay üstünde -->
                    <Grid Grid.Row="0" VerticalAlignment="Bottom" Margin="12,0,12,10" Panel.ZIndex="5">
                        <StackPanel VerticalAlignment="Bottom">
                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,0,1">
                                <TextBlock.Text>
                                    <Binding Path="Title">
                                        <Binding.FallbackValue>Oyun Adı</Binding.FallbackValue>
                                    </Binding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextLight}" FontSize="9">
                                <Run>
                                    <Run.Text>
                                        <Binding Path="Developer">
                                            <Binding.FallbackValue>Geliştirici</Binding.FallbackValue>
                                        </Binding>
                                    </Run.Text>
                                </Run>
                                <Run Text=" • "/>
                                <Run>
                                    <Run.Text>
                                        <Binding Path="ReleaseYear" Mode="OneWay">
                                            <Binding.FallbackValue>Yıl</Binding.FallbackValue>
                                        </Binding>
                                    </Run.Text>
                                </Run>
                            </TextBlock>
                            <Separator Background="{StaticResource BorderDark}" Margin="0,6,0,6" Opacity="0.4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <dx:DXImage Width="14" Height="14" Margin="0,0,5,0" Stretch="Uniform">
                                    <dx:DXImage.Source>
                                        <Binding Path="PlatformIcon" Mode="OneWay">
                                            <Binding.FallbackValue>/ZImages/controller.svg</Binding.FallbackValue>
                                        </Binding>
                                    </dx:DXImage.Source>
                                </dx:DXImage>
                                <TextBlock Foreground="{StaticResource TextLight}" FontSize="9" FontWeight="Medium">
                                    <TextBlock.Text>
                                        <Binding Path="Platform">
                                            <Binding.FallbackValue>Platform</Binding.FallbackValue>
                                        </Binding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource TextLight}" FontSize="9" Margin="8,0,0,0">
                                    <Run Text="||"/>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource TextLight}" FontSize="9" Margin="8,0,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} s oynandı">
                                            <Binding Path="PlayTime" Converter="{StaticResource PlayTimeConverter}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GameListItemTemplate">
            <Border Height="100" Margin="20,0,20,12" CornerRadius="12" 
                    Background="{StaticResource CardDark}" 
                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                    Cursor="Hand"
                    PreviewMouseLeftButtonDown="GameCard_PreviewMouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" Opacity="0.2" ShadowDepth="2"/>
                </Border.Effect>

                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Görsel -->
                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True">
                        <Border.Background>
                            <ImageBrush Stretch="UniformToFill">
                                <ImageBrush.ImageSource>
                                    <Binding Path="CoverImageUrl"/>
                                </ImageBrush.ImageSource>
                            </ImageBrush>
                        </Border.Background>
                    </Border>

                    <!-- Bilgiler -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title, FallbackValue=Oyun Adı}" Foreground="White" 
                                   FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                        <TextBlock Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,4">
                            <Run Text="{Binding Developer, Mode=OneWay, FallbackValue=Geliştirici}"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding ReleaseYear, Mode=OneWay, FallbackValue=Yıl}"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding Platform, Mode=OneWay, FallbackValue=Platform}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Description}" Foreground="#6B7280" FontSize="11" 
                                   TextTrimming="CharacterEllipsis" MaxHeight="16" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Durum ve Puan -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="20,0,0,0">
                        <Border CornerRadius="10" Padding="12,5" Margin="0,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#2b6cee"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Tamamlandı">
                                            <Setter Property="Background" Value="#ef4444"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Bırakıldı">
                                            <Setter Property="Background" Value="#64748b"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="İstek Listesi">
                                            <Setter Property="Background" Value="#22c55e"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding Status, FallbackValue=Oynuyor}" Foreground="White" 
                                       FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Foreground="White" FontSize="14" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1}">
                                        <Binding Path="UserRating" FallbackValue="0"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AddGameCardTemplate">
            <dx:SimpleButton Click="BtnAddGame_Click" Cursor="Hand" Width="340" Height="220" Margin="0,0,20,20" Padding="0">
                <dx:SimpleButton.Template>
                    <ControlTemplate TargetType="dx:SimpleButton">
                        <Border x:Name="MainBorder" CornerRadius="16" Background="Transparent" 
                                BorderBrush="{StaticResource BorderDark}" BorderThickness="2">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#2b6cee" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#102b6cee" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <StackPanel x:Name="MainContent" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="60" Height="60" CornerRadius="30" Background="{StaticResource CardDark}" Margin="0,0,0,15">
                                    <dx:DXImage Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_Add.svg'}" Width="32" Height="32"/>
                                </Border>
                                <TextBlock Text="Yeni Oyun Ekle" Foreground="{StaticResource TextLight}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </dx:SimpleButton.Template>
            </dx:SimpleButton>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="#FF0C111A">
        <Grid.RenderTransform>
            <TranslateTransform Y="20"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource SlideUpFadeIn}"/>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="40,30,40,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Başlık ve Özet Alt Alta -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Oyunlar" FontSize="28" FontWeight="Black" Foreground="White" Margin="0,15,0,0"/>
                    <TextBlock x:Name="StatsText"
                               FontSize="13"
                               Foreground="{StaticResource TextLight}"
                               Margin="0,4,0,0"
                               FontWeight="Bold"
                               Cursor="Hand"
                               MouseDown="StatsText_MouseDown">
                        Toplam 0 oyun • 0 tamamlandı
                    </TextBlock>
                </StackPanel>

                <dx:SimpleButton Grid.Column="1" Content="İçerik Ekle" Height="40" Padding="25,0"
                                 Background="{StaticResource PrimaryBlue}" Foreground="White" 
                                 CornerRadius="10" FontSize="14" FontWeight="Bold"
                                 Glyph="/ZImages/add.svg" Cursor="Hand" Click="BtnAddGame_Click" 
                                 GlyphHeight="24" GlyphWidth="24" VerticalAlignment="Center"/>
            </Grid>

            <!-- İstatistik Paneli ve Butonlar Yan Yana -->
            <Grid Grid.Row="1" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Detaylı İstatistikler Paneli (Sola Yaslı) -->
                <Border x:Name="DetailedStatsPanel" Grid.Column="0" Background="{StaticResource CardDark}" CornerRadius="12" 
                        BorderBrush="{StaticResource BorderDark}" BorderThickness="1" 
                        Padding="20" Margin="0,0,20,0" Visibility="Visible"
                        Cursor="Hand" MouseDown="DetailedStatsPanel_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Toplam Oyun - Mavi Tema -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="🎮" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Toplam Oyun" Foreground="{StaticResource TextLight}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtTotalGames" Text="0" Foreground="#60a5fa" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="TrendTotalGames" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Tamamlanan Oyun - Yeşil Tema -->
                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="✅" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tamamlanan Oyun" Foreground="{StaticResource TextLight}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtCompletedGames" Text="0" Foreground="#10b981" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="TrendCompletedGames" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Oynanıyor - Kırmızı/Turuncu Tema (YENİ) -->
                        <StackPanel Grid.Column="2" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="🕹️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Oynanıyor" Foreground="{StaticResource TextLight}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtPlayingGames" Text="0" Foreground="#ef4444" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="TrendPlayingGames" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Toplam Süre - Mor Tema -->
                        <StackPanel Grid.Column="3" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="⏱️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Toplam Geçirilen Süre" Foreground="{StaticResource TextLight}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtTotalPlayTime" Text="0s" Foreground="#a78bfa" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="TrendPlayTime" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Ortalama Rating - Sarı Tema -->
                        <StackPanel Grid.Column="4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="⭐" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ortalama Rating" Foreground="{StaticResource TextLight}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtAvgRating" Text="0.0" Foreground="#fbbf24" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="TrendRating" Text="→" Foreground="#6b7280" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Butonlar (Sağa Yaslı ve Dikey Ortalanmış) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <dx:SimpleButton x:Name="BtnBulkActions" Content="Toplu İşlem" Height="40" Margin="0,0,10,0" Padding="15,0"
                                     Background="{StaticResource CardDark}" Foreground="{StaticResource TextLight}" 
                                     CornerRadius="10" FontSize="13" FontWeight="Bold" Cursor="Hand"
                                     Click="BtnBulkActions_Click" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Toplu İşlemler Toolbar (Popup gibi overlay) -->
                <Border x:Name="BulkActionsToolbar" Grid.Column="1"
                        Background="{StaticResource CardDark}" CornerRadius="10" BorderBrush="{StaticResource BorderDark}" 
                        BorderThickness="1" Padding="15" Margin="0,50,0,0" Visibility="Collapsed"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="50">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtSelectedCount" Text="0 seçili" Foreground="{StaticResource TextLight}" 
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <dx:SimpleButton Content="Favoriye Ekle" Height="35" Padding="12,0" Margin="0,0,8,0"
                                         Background="Transparent" Foreground="{StaticResource TextLight}" 
                                         CornerRadius="8" FontSize="12" Cursor="Hand"
                                         Click="BtnBulkAddFavorite_Click"/>
                        <dx:SimpleButton Content="Favoriden Çıkar" Height="35" Padding="12,0" Margin="0,0,8,0"
                                         Background="Transparent" Foreground="{StaticResource TextLight}" 
                                         CornerRadius="8" FontSize="12" Cursor="Hand"
                                         Click="BtnBulkRemoveFavorite_Click"/>
                        <dx:SimpleButton Content="Sil" Height="35" Padding="12,0" Margin="0,0,8,0"
                                         Background="#ef4444" Foreground="White" 
                                         CornerRadius="8" FontSize="12" FontWeight="Bold" Cursor="Hand"
                                         Click="BtnBulkDelete_Click"/>
                        <dx:SimpleButton Content="İptal" Height="35" Padding="12,0"
                                         Background="Transparent" Foreground="{StaticResource TextLight}" 
                                         CornerRadius="8" FontSize="12" Cursor="Hand"
                                         Click="BtnBulkCancel_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Margin="40,10,40,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardDark}" CornerRadius="10" Height="44" BorderBrush="{StaticResource BorderDark}" BorderThickness="1">
                <dxe:ButtonEdit x:Name="TxtSearch" NullText="Kütüphanede ara (örn: Witcher, Cyberpunk...)" 
                                ShowBorder="False" AllowDefaultButton="False"
                                Background="Transparent" Foreground="White" 
                                VerticalContentAlignment="Center" Padding="0,0" FontSize="13" Height="40"
                                EditValueChanged="TxtSearch_EditValueChanged">
                    <dxe:ButtonEdit.Buttons>
                        <dxe:ButtonInfo IsLeft="True" IsDefaultButton="False">
                            <Image Source="/ZImages/search_png.png" Width="25" Height="25" Margin="12,0,5,0" Opacity="0.5"/>
                        </dxe:ButtonInfo>
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>
            </Border>

            <!-- Filtreleme Popup (overlay) -->
            <Popup x:Name="FilterPopup"
                   PlacementTarget="{Binding ElementName=BtnFilter}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   VerticalOffset="10">
                <Border Background="{StaticResource SurfaceDark}" 
                        CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                        Padding="20" Width="280">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Filtreleme Seçenekleri" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                        <!-- Platform -->
                        <TextBlock Text="Platform" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Margin="0,0,0,15">
                            <dxe:CheckEdit Content="PC (Steam)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Platform_Steam"/>
                            <dxe:CheckEdit Content="PlayStation 5" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Platform_PS5"/>
                            <dxe:CheckEdit Content="Xbox Series X" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Platform_Xbox"/>
                            <dxe:CheckEdit Content="Nintendo Switch" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Platform_Switch"/>
                            <dxe:CheckEdit Content="Mobil" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Platform_Mobile"/>
                        </StackPanel>

                        <Separator Background="{StaticResource BorderColor}" Opacity="0.5" Margin="0,0,0,15"/>

                        <!-- Puan Aralığı -->
                        <TextBlock Text="Puan Aralığı" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Margin="0,0,0,15">
                            <dxe:CheckEdit Content="Şaheserler (9-10 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_9_10"/>
                            <dxe:CheckEdit Content="İyiler (7-8 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_7_8"/>
                            <dxe:CheckEdit Content="Ortalamalar (5-6 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_5_6"/>
                            <dxe:CheckEdit Content="Puanlanmamışlar" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_Unrated"/>
                        </StackPanel>

                        <Separator Background="{StaticResource BorderColor}" Opacity="0.5" Margin="0,0,0,15"/>

                        <!-- Yıl -->
                        <TextBlock Text="Çıkış Yılı" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Margin="0,0,0,15">
                            <dxe:CheckEdit Content="Son 5 Yıl" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Year_Last5"/>
                            <dxe:CheckEdit Content="2010 - 2020 Arası" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Year_2010_2020"/>
                            <dxe:CheckEdit Content="Klasikler (2010 Öncesi)" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Year_Oldies"/>
                        </StackPanel>

                        <dx:SimpleButton Content="Filtreleri Temizle" Height="30" Margin="0,10,0,0"
                                         Background="Transparent" Foreground="{StaticResource PrimaryBlue}" 
                                         FontWeight="Bold" Cursor="Hand" Click="BtnClearFilters_Click"/>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Sıralama Popup (overlay) -->
            <Popup x:Name="SortPopup"
                   PlacementTarget="{Binding ElementName=BtnSort}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   VerticalOffset="10">
                <Border Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="20" Width="260">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Sıralama" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        <ListBox x:Name="SortListBox" Background="Transparent" BorderThickness="0" SelectionChanged="SortOption_Changed">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border" Padding="10,8" CornerRadius="6" Background="Transparent" Cursor="Hand">
                                                    <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Foreground="White" FontSize="13"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#232f48"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBoxItem Content="Eklenme Tarihi (Yeni > Eski)" Tag="Date_Desc" IsSelected="True"/>
                            <ListBoxItem Content="Eklenme Tarihi (Eski > Yeni)" Tag="Date_Asc"/>
                            <ListBoxItem Content="İsim (A > Z)" Tag="Title_Asc"/>
                            <ListBoxItem Content="İsim (Z > A)" Tag="Title_Desc"/>
                            <ListBoxItem Content="Puan (Yüksek > Düşük)" Tag="Rating_Desc"/>
                            <ListBoxItem Content="Puan (Düşük > Yüksek)" Tag="Rating_Asc"/>
                            <ListBoxItem Content="Oynama Süresi (Çok > Az)" Tag="PlayTime_Desc"/>
                            <ListBoxItem Content="Oynama Süresi (Az > Çok)" Tag="PlayTime_Asc"/>
                            <ListBoxItem Content="Çıkış Yılı (Yeni > Eski)" Tag="Year_Desc"/>
                            <ListBoxItem Content="Çıkış Yılı (Eski > Yeni)" Tag="Year_Asc"/>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Margin="40,10,40,10" Padding="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Sekmeler (Sol) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Height="40">
                    <RadioButton x:Name="RadioTumu" Content="Tümü" Tag="Tümü" IsChecked="True" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton x:Name="RadioDevamEdenler" Content="Devam Edenler" Tag="Devam Edenler" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton x:Name="RadioTamamlandi" Content="Tamamlandı" Tag="Tamamlandı" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton x:Name="RadioBirakildi" Content="Bırakıldı" Tag="Bırakıldı" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton x:Name="RadioIstekListesi" Content="İstek Listesi" Tag="İstek Listesi" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                </StackPanel>
                
                <!-- Filtrele, Sırala ve Görünüm Butonları (Sağ) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Height="40">
                    <dx:SimpleButton x:Name="BtnFilter" Content="Filtrele" Height="40" Margin="0,0,10,0" Padding="15,0"
                                     Background="{StaticResource CardDark}" Foreground="{StaticResource TextLight}" 
                                     CornerRadius="10" FontSize="13" FontWeight="Bold" Glyph="/ZImages/filter_list.svg"
                                     Click="BtnFilter_Click" GlyphHeight="24" GlyphWidth="24"/>
                    <dx:SimpleButton x:Name="BtnSort" Content="Sırala" Height="40" Margin="0,0,10,0" Padding="15,0"
                                     Background="{StaticResource CardDark}" Foreground="{StaticResource TextLight}" 
                                     CornerRadius="10" FontSize="13" FontWeight="Bold" Glyph="/ZImages/sort.svg"
                                     Click="BtnSort_Click" GlyphHeight="24" GlyphWidth="24"/>
                    <TextBlock Text="||" Foreground="{StaticResource TextLight}" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <dx:SimpleButton x:Name="BtnViewGrid" Height="40" Width="40"
                                     Background="{StaticResource CardDark}" Foreground="{StaticResource TextLight}" 
                                     CornerRadius="10" Cursor="Hand" Click="BtnViewGrid_Click"
                                     Glyph="/ZImages/grid_view.svg" Margin="0,0,5,0" GlyphHeight="24" GlyphWidth="24"/>
                    <dx:SimpleButton x:Name="BtnViewList" Height="40" Width="40"
                                     Background="{StaticResource CardDark}" Foreground="{StaticResource TextLight}" 
                                     CornerRadius="10" Cursor="Hand" Click="BtnViewList_Click"
                                     Glyph="/ZImages/view_list.svg" Opacity="0.5" GlyphHeight="24" GlyphWidth="24"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="3" Margin="0,30,0,0" Padding="20,0,20,40" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Grid Görünümü -->
                <ItemsControl x:Name="GamesGridControl" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate" Value="{StaticResource GameCardTemplate}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="Add">
                                                <Setter Property="ContentTemplate" Value="{StaticResource AddGameCardTemplate}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Liste Görünümü -->
                <ItemsControl x:Name="GamesListControl" HorizontalAlignment="Stretch" Visibility="Collapsed"
                              ItemTemplate="{StaticResource GameListItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>