<UserControl x:Class="HobbyTracker.Views.EditSeriesWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0F172A">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0F172A"/>
        <SolidColorBrush x:Key="CardDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#334155"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextGray" Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextWhite" Color="#F1F5F9"/>

        <!-- Genre Tag Style -->
        <Style x:Key="GenreTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,30,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="0,10">
                            <TextBlock x:Name="Text" Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="Text" Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="Text" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Progress Bar Style -->
        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#232f48"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" Height="6">
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3" Height="6"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Backdrop Image -->
        <Grid Height="350" VerticalAlignment="Top">
            <Image x:Name="BackdropImage" Source="{Binding BackdropUrl}" Stretch="UniformToFill">
                <Image.Effect>
                    <BlurEffect Radius="30"/>
                </Image.Effect>
            </Image>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#80000000" Offset="0"/>
                        <GradientStop Color="#0F172A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Breadcrumb -->
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Tabs -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                </Grid.RowDefinitions>

                <!-- 1. BREADCRUMB -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                    <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource CardDark}" 
                            Cursor="Hand" MouseLeftButtonUp="BtnBack_Click" Margin="0,0,15,0" VerticalAlignment="Center">
                        <TextBlock Text="←" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25"/>
                    </Border>
                    <TextBlock Text="Diziler" Foreground="{StaticResource TextGray}" FontSize="13" Cursor="Hand" 
                               MouseLeftButtonUp="BtnBack_Click" VerticalAlignment="Center"/>
                    <TextBlock Text=" / " Foreground="{StaticResource TextGray}" FontSize="13" Margin="8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="BreadcrumbTitle" Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 2. HEADER -->
                <Grid Grid.Row="1" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Poster -->
                        <ColumnDefinition Width="*"/>    <!-- Info -->
                    </Grid.ColumnDefinitions>

                    <!-- Poster -->
                    <Border Grid.Column="0" Width="180" Height="270" CornerRadius="12" Margin="0,0,30,0">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                        </Border.Effect>
                        <Border.Background>
                            <ImageBrush x:Name="PosterImage" ImageSource="{Binding CoverImageUrl}" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <!-- Series Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitle" Text="{Binding Title}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock x:Name="TxtYear" Text="{Binding Year}" Foreground="{StaticResource TextGray}" FontSize="14"/>
                            <TextBlock Text="  •  " Foreground="{StaticResource TextGray}" FontSize="14"/>
                            <TextBlock x:Name="TxtNetwork" Text="{Binding Network}" Foreground="{StaticResource TextGray}" FontSize="14"/>
                            <TextBlock Text="  •  " Foreground="{StaticResource TextGray}" FontSize="14"/>
                            <TextBlock x:Name="TxtSeasons" Text="{Binding TotalSeasons, StringFormat='{}{0} Sezon'}" Foreground="{StaticResource TextGray}" FontSize="14"/>
                            <TextBlock Text="  •  " Foreground="{StaticResource TextGray}" FontSize="14"/>
                            <TextBlock x:Name="TxtEpisodes" Text="{Binding TotalEpisodes, StringFormat='{}{0} Bölüm'}" Foreground="{StaticResource TextGray}" FontSize="14"/>
                        </StackPanel>

                        <!-- User Rating, Status, Favorite Row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            
                            <!-- TMDB Rating (Yellow) -->
                            <Border Background="{StaticResource CardDark}" CornerRadius="18" Padding="12,0" Height="36" Margin="0,0,15,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="★" Foreground="#fbbf24" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtTmdbRating" Text="{Binding TmdbRating, StringFormat='{}{0:0.0}'}" Foreground="#fbbf24" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text="/10" Foreground="{StaticResource TextGray}" FontSize="11" Margin="2,0,0,2" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </Border>

                            <!-- User Star Rating with Popup -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Popup x:Name="StarPopupHeader"
                                       PlacementTarget="{Binding ElementName=BtnStarSelectHeader}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       VerticalOffset="6">
                                    <Border Background="{StaticResource CardDark}" CornerRadius="10" Padding="12" 
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                                        </Border.Effect>
                                        <StackPanel Orientation="Horizontal" x:Name="StarContainerHeader"/>
                                    </Border>
                                </Popup>
                                
                                <Border x:Name="BtnStarSelectHeader" Height="36" CornerRadius="18" Background="{StaticResource CardDark}" 
                                        Padding="12,0" Cursor="Hand" MouseLeftButtonUp="BtnStarSelectHeader_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#374151"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="★" Foreground="#3B82F6" FontSize="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtStarRating" Text="0/10" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Status Dropdown -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Popup x:Name="StatusPopupHeader"
                                       PlacementTarget="{Binding ElementName=BtnStatusSelectHeader}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       VerticalOffset="6">
                                    <Border Background="{StaticResource CardDark}" CornerRadius="10" Padding="8" 
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Width="160">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <Border Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                    MouseLeftButtonUp="StatusOptionHeader_Click" Tag="Completed">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#374151"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="İzlendi" Foreground="White" FontSize="13"/>
                                            </Border>
                                            <Border Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                    MouseLeftButtonUp="StatusOptionHeader_Click" Tag="InProgress">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#374151"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="İzleniyor" Foreground="White" FontSize="13"/>
                                            </Border>
                                            <Border Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                    MouseLeftButtonUp="StatusOptionHeader_Click" Tag="PlanToWatch">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#374151"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="Listem" Foreground="White" FontSize="13"/>
                                            </Border>
                                            <Border Padding="10,8" CornerRadius="6" Cursor="Hand" 
                                                    MouseLeftButtonUp="StatusOptionHeader_Click" Tag="Dropped">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#374151"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="Yarım Bırakıldı" Foreground="White" FontSize="13"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                                
                                <Border x:Name="BtnStatusSelectHeader" Height="36" CornerRadius="18" 
                                        Background="{StaticResource PrimaryBlue}" Padding="20,0"
                                        Cursor="Hand" MouseLeftButtonUp="BtnStatusSelectHeader_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtStatusDisplayHeader" Text="İzlendi" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Text=" ▼" Foreground="White" FontSize="10" VerticalAlignment="Center" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Favorite Button -->
                            <Border x:Name="BtnFavorite" Width="36" Height="36" CornerRadius="18" Background="#374151" 
                                    Cursor="Hand" MouseLeftButtonUp="BtnFavorite_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4B5563"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock x:Name="TxtFavoriteIcon" Text="🤍" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Genres -->
                        <ItemsControl x:Name="GenresItemsControl" Margin="0,0,0,15">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GenreTagStyle}">
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextGray}" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Synopsis -->
                        <TextBlock x:Name="TxtSynopsis" Text="{Binding Overview}" Foreground="{StaticResource TextGray}" 
                                   FontSize="14" TextWrapping="Wrap" LineHeight="22" MaxWidth="600" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <!-- 3. TABS -->
                <Border Grid.Row="2" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TabOverview" Content="Genel Bakış" IsChecked="True" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked" Tag="Overview"/>
                        <RadioButton x:Name="TabEpisodes" Content="Bölümler" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked" Tag="Episodes"/>
                        <RadioButton x:Name="TabCast" Content="Oyuncular" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked" Tag="Cast"/>
                        <RadioButton x:Name="TabNotes" Content="Kişisel Notlar" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked" Tag="Notes"/>
                    </StackPanel>
                </Border>

                <!-- 4. CONTENT AREA -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>      <!-- Main Content -->
                        <ColumnDefinition Width="320"/>   <!-- Sidebar -->
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Main Content -->
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">

                        <!-- Overview Tab Content -->
                        <StackPanel x:Name="OverviewContent">
                            <!-- Özet -->
                            <TextBlock Text="Özet" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtSynopsisContent" Text="{Binding Overview}" FontSize="14" Foreground="{StaticResource TextGray}" 
                                       TextWrapping="Wrap" LineHeight="24" Margin="0,0,0,30"/>

                            <!-- Personal Notes Card -->
                            <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20" Margin="0,0,0,30">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="Kişisel Notlar" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Hand" MouseLeftButtonUp="BtnEditNotes_Click">
                                            <TextBlock Text="✏️" FontSize="12" Margin="0,0,5,0"/>
                                            <TextBlock Text="Düzenle" Foreground="{StaticResource PrimaryBlue}" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <TextBlock x:Name="TxtPersonalNotePreview" Text="{Binding PersonalNote}" FontSize="13" Foreground="{StaticResource TextGray}" 
                                               FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                    <!-- User Tags -->
                                    <ItemsControl x:Name="UserTagsList" ItemsSource="{Binding UserTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#3B82F6" CornerRadius="12" Padding="12,6" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Başrol Oyuncuları -->
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Başrol Oyuncuları" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Tümünü gör" Foreground="{StaticResource PrimaryBlue}" FontSize="13" HorizontalAlignment="Right" 
                                           Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="BtnSeeAllCast_Click"/>
                            </Grid>

                            <ItemsControl x:Name="CastPreviewList" ItemsSource="{Binding Cast}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="90" Margin="0,0,20,0">
                                            <Border Width="70" Height="70" CornerRadius="35" Margin="0,0,0,10">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" FontWeight="SemiBold" 
                                                       TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Character}" Foreground="{StaticResource TextGray}" FontSize="10" 
                                                       TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Episodes Tab Content -->
                        <StackPanel x:Name="EpisodesContent" Visibility="Collapsed">
                            <!-- Season Selector Header -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Season Dropdown -->
                                <Border x:Name="SeasonSelectorBorder" Background="{StaticResource CardDark}" CornerRadius="8" 
                                        Padding="15,10" Cursor="Hand" MouseLeftButtonUp="SeasonSelector_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TxtSelectedSeason" Text="Sezon 1" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Text="▼" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Season Progress -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtSeasonProgress" Text="0/0 İzlendi" Foreground="{StaticResource TextGray}" FontSize="13" Margin="0,0,15,0"/>
                                    <Border x:Name="SeasonProgressBar" Background="#334155" CornerRadius="4" Width="100" Height="8">
                                        <Border x:Name="SeasonProgressFill" Background="#22C55E" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Season Selector Popup -->
                            <Popup x:Name="SeasonPopup" PlacementTarget="{Binding ElementName=SeasonSelectorBorder}" Placement="Bottom" 
                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="5">
                                <Border Background="{StaticResource CardDark}" BorderBrush="{StaticResource BorderColor}" 
                                        BorderThickness="1" CornerRadius="8" MaxHeight="300">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="SeasonListPanel"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            
                            <!-- Mark Season as Watched Button -->
                            <Border Background="{StaticResource SurfaceDark}" CornerRadius="8" Padding="15,12" Margin="0,0,0,20" 
                                    Cursor="Hand" MouseLeftButtonUp="BtnMarkSeasonWatched_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="✓" Foreground="#22C55E" FontSize="16" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tüm Sezonu İzledim Olarak İşaretle" Foreground="White" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Episode List -->
                            <ItemsControl x:Name="EpisodesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="15" Margin="0,0,0,12" 
                                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Episode Thumbnail -->
                                                <Border CornerRadius="8" Height="70" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding StillPath}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                    <!-- Fallback if no image -->
                                                    <Border Background="#1a2230" CornerRadius="8" Visibility="{Binding StillPath, Converter={x:Null}}">
                                                        <TextBlock Text="📺" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </Border>
                                                
                                                <!-- Episode Info -->
                                                <StackPanel Grid.Column="1" Margin="15,0,10,0" VerticalAlignment="Center">
                                                    <!-- Badge, Date, Runtime -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                        <Border Background="{StaticResource PrimaryBlue}" CornerRadius="4" Padding="6,2" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding EpisodeCode}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding AirDate}" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" • " Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding RuntimeText}" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Title -->
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="15" FontWeight="SemiBold" 
                                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,3"/>
                                                    
                                                    <!-- Overview -->
                                                    <TextBlock Text="{Binding Overview}" Foreground="{StaticResource TextGray}" FontSize="12" 
                                                               TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="36"/>
                                                </StackPanel>
                                                
                                                <!-- Watched Toggle -->
                                                <Border Grid.Column="2" Width="40" Height="40" CornerRadius="20" 
                                                        Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Tag="{Binding}" MouseLeftButtonUp="BtnToggleEpisodeWatched_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#334155"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                                                    <Setter Property="Background" Value="#3B82F6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Cast Tab Content -->
                        <StackPanel x:Name="CastContent" Visibility="Collapsed">
                            <TextBlock Text="Oyuncular" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                            
                            <ItemsControl x:Name="FullCastList" ItemsSource="{Binding Cast}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="12" Margin="0,0,15,15" Width="180">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="50" Height="50" CornerRadius="25" Margin="0,0,12,0">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" Width="100">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" FontWeight="SemiBold" 
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Character}" Foreground="{StaticResource TextGray}" FontSize="11" 
                                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Notes Tab Content -->
                        <StackPanel x:Name="NotesContent" Visibility="Collapsed">
                            <TextBlock Text="Kişisel Notlar" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                            
                            <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBox x:Name="TxtNotesEditor" 
                                             Text="{Binding PersonalNote, Mode=TwoWay}" 
                                             Background="#1E293B" Foreground="White" 
                                             BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                             Padding="15" FontSize="14" 
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             MinHeight="200" MaxHeight="400"
                                             VerticalScrollBarVisibility="Auto"/>
                                    
                                    <dx:SimpleButton Content="Notları Kaydet" Height="40" Margin="0,15,0,0"
                                                     Background="{StaticResource PrimaryBlue}" Foreground="White" 
                                                     CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                     Click="BtnSaveNotes_Click"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- User Tags Section -->
                            <TextBlock Text="Etiketler" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,30,0,15"/>
                            <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <!-- Existing Tags -->
                                    <ItemsControl x:Name="TagsItemControl" ItemsSource="{Binding UserTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#3B82F6" CornerRadius="12" Padding="10,6" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" ✕" Foreground="#FFFFFF" FontSize="12" Cursor="Hand" VerticalAlignment="Center"
                                                                   MouseLeftButtonUp="BtnRemoveTag_Click" Tag="{Binding}" Opacity="0.7"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <!-- Add New Tag Input -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBox x:Name="TxtNewTag" Grid.Column="0"
                                                 Background="#1E293B" Foreground="White" 
                                                 BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                                 Padding="12,10" FontSize="13" 
                                                 VerticalContentAlignment="Center"
                                                 KeyDown="TxtNewTag_KeyDown"/>
                                        
                                        <dx:SimpleButton Grid.Column="1" Content="Ekle" Width="80" Height="38" Margin="10,0,0,0"
                                                         Background="{StaticResource PrimaryBlue}" Foreground="White" 
                                                         CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                         Click="BtnAddTag_Click"/>
                                    </Grid>
                                    
                                    <TextBlock Text="İpucu: Virgülle ayırarak birden fazla etiket ekleyebilirsiniz" 
                                               Foreground="{StaticResource TextGray}" FontSize="11" Margin="0,10,0,0" FontStyle="Italic"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- RIGHT: Sidebar -->
                    <StackPanel Grid.Column="1">
                        <!-- Watching Progress Card -->
                        <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="İzleme İlerlemesi" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock x:Name="TxtProgressPercent" HorizontalAlignment="Right" FontSize="14" FontWeight="Bold" Foreground="#10B981"
                                               Text="{Binding ProgressPercentage, StringFormat='{}{0}%'}"/>
                                </Grid>

                                <Border x:Name="SidebarProgressBackground" Background="#232f48" CornerRadius="3" Height="6" Margin="0,0,0,15">
                                    <Border x:Name="SidebarProgressFill" Background="#3B82F6" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                                </Border>

                                <Grid Margin="0,0,0,20">
                                    <TextBlock x:Name="TxtProgressText" Text="{Binding ProgressText}" Foreground="{StaticResource TextGray}" FontSize="12"/>
                                    <TextBlock x:Name="TxtProgressStatus" Text="Completed" Foreground="{StaticResource TextGray}" FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>

                                <dx:SimpleButton x:Name="BtnUpdateProgress" Content="İlerleme Güncelle" Height="40"
                                                 Background="Transparent" Foreground="White" 
                                                 BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                                 CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                 Click="BtnUpdateProgress_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Details Card -->
                        <Border Background="{StaticResource CardDark}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="DURUM" Foreground="{StaticResource TextGray}" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="TxtStatusSidebar" Text="{Binding StatusDisplay}" Foreground="White" FontSize="13"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="YAYINCI" Foreground="{StaticResource TextGray}" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Network}" Foreground="White" FontSize="13"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ORİJİNAL DİL" Foreground="{StaticResource TextGray}" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding OriginalLanguage}" Foreground="White" FontSize="13"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Delete Button -->
                        <dx:SimpleButton Content="🗑️ Diziyi Sil" Height="45"
                                         Background="#DC2626" Foreground="White" 
                                         CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                         Click="BtnDeleteSeries_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Delete Confirmation Overlay -->
        <Grid x:Name="DeleteOverlay" Visibility="Collapsed" Background="#80000000">
            <Border Background="{StaticResource CardDark}" CornerRadius="16" Padding="30" Width="400" 
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Diziyi Sil" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="Bu diziyi silmek istediğinize emin misiniz? Bu işlem geri alınamaz." 
                               Foreground="{StaticResource TextGray}" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <dx:SimpleButton Content="İptal" Width="120" Height="40" Background="{StaticResource SurfaceDark}" 
                                         Foreground="White" FontWeight="Bold" CornerRadius="8" Margin="0,0,15,0"
                                         Click="BtnCancelDelete_Click"/>
                        <dx:SimpleButton Content="Sil" Width="120" Height="40" Background="#EF4444" 
                                         Foreground="White" FontWeight="Bold" CornerRadius="8"
                                         Click="BtnConfirmDelete_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
