<UserControl x:Class="HobbyTracker.Views.SeriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="#FF0C111A">

    <UserControl.Resources>
        <Storyboard x:Key="SlideUpFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <SolidColorBrush x:Key="BgDark" Color="#FF0C111A"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#161d2a"/>
        <SolidColorBrush x:Key="BorderColor" Color="#232f48"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2b6cee"/>
        <SolidColorBrush x:Key="TextGray" Color="#92a4c9"/>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Progress Bar Style -->
        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="MaxHeight" Value="6"/>
            <Setter Property="Background" Value="#232f48"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" Height="6">
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3" Height="6"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3" Height="6">
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B82F6" BlurRadius="4" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Series Card Template (Grid View) -->
        <DataTemplate x:Key="SeriesCardTemplate">
            <Border Height="200" Width="280" CornerRadius="12" Background="#1F2937" Margin="0,0,15,15" Cursor="Hand"
                    Tag="{Binding}" MouseLeftButtonUp="SeriesCard_Click">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.3" ShadowDepth="3"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" CornerRadius="12,12,0,0">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding BackdropUrl}" Stretch="UniformToFill"/>
                        </Border.Background>
                        <Grid>
                            <Border Background="#20000000" CornerRadius="12,12,0,0"/>
                            <!-- Status Badge -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                    Background="{Binding StatusBadgeBackground}" 
                                    CornerRadius="10" Padding="8,4">
                                <TextBlock Text="{Binding StatusDisplay}" Foreground="White" 
                                           FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <!-- Season/Episode Badge -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"
                                    Background="#1F2937" CornerRadius="6" Padding="6,3">
                                <TextBlock Text="{Binding ProgressText}" Foreground="#9CA3AF" FontSize="10"/>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="12,10,12,12">
                        <TextBlock Text="{Binding Title}" 
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   TextTrimming="CharacterEllipsis"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Network}" Foreground="#9CA3AF" FontSize="11"/>
                            <TextBlock Grid.Column="1" Foreground="#22C55E" FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <Binding Path="ProgressPercentage" StringFormat="{}{0}%"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>

                        <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}" Maximum="100"
                                     Style="{StaticResource ModernProgressBarStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Series List Item Template (List View) -->
        <DataTemplate x:Key="SeriesListItemTemplate">
            <Border Height="100" CornerRadius="12" Background="#1F2937" Margin="0,0,0,10" Cursor="Hand"
                    Tag="{Binding}" MouseLeftButtonUp="SeriesCard_Click">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" Opacity="0.2" ShadowDepth="2"/>
                </Border.Effect>

                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Poster -->
                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding BackdropUrl}" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <!-- Info -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Foreground="White" 
                                   FontWeight="Bold" FontSize="15" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Foreground="#9CA3AF" FontSize="11">
                                <Run Text="{Binding Network, Mode=OneWay, FallbackValue=Kanal}"/>
                                <Run Text=" • "/>
                                <Run Text="{Binding Year, Mode=OneWay, FallbackValue=Yıl}"/>
                                <Run Text=" • "/>
                                <Run Text="{Binding TotalSeasons, Mode=OneWay, StringFormat={}{0} Sezon}"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding Overview}" Foreground="#6B7280" FontSize="10" 
                                   TextTrimming="CharacterEllipsis" MaxHeight="16" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Status & Rating -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="15,0,0,0">
                        <Border Background="{Binding StatusBadgeBackground}" CornerRadius="6" Padding="8,4" Margin="0,0,0,8">
                            <TextBlock Text="{Binding StatusDisplay}" Foreground="White" 
                                       FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="12" Margin="0,0,3,0"/>
                            <TextBlock Foreground="White" FontSize="11" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1}">
                                        <Binding Path="UserRating" FallbackValue="0"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Foreground="#9CA3AF" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="ProgressText" FallbackValue=""/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AddSeriesCardTemplate">
            <dx:SimpleButton Click="BtnAddSeries_Click" Cursor="Hand" Width="280" Height="200" Margin="0,0,15,15" Padding="0">
                <dx:SimpleButton.Template>
                    <ControlTemplate TargetType="dx:SimpleButton">
                        <Border x:Name="MainBorder" CornerRadius="12" Background="Transparent" 
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="2">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#2b6cee" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#102b6cee" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <StackPanel x:Name="MainContent" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="60" Height="60" CornerRadius="30" Background="{StaticResource SurfaceDark}" Margin="0,0,0,15">
                                    <dx:DXImage Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_Add.svg'}" Width="32" Height="32"/>
                                </Border>
                                <TextBlock Text="Yeni Dizi Ekle" Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </dx:SimpleButton.Template>
            </dx:SimpleButton>
        </DataTemplate>

        <!-- Modern Filter Tab Style -->
        <Style x:Key="ModernFilterTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="Text" Text="{TemplateBinding Content}" 
                                       Foreground="{TemplateBinding Foreground}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0"/>
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                                <Setter TargetName="Text" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SlideUpFadeIn}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="RootGrid" Margin="30" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform/>
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Başlık ve Özet -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Diziler" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="StatsText"
                               FontSize="13"
                               Foreground="{StaticResource TextGray}"
                               Margin="0,4,0,0"
                               FontWeight="Bold"
                               Cursor="Hand"
                               MouseDown="StatsText_MouseDown">
                        Toplam 0 dizi • 0 izlendi
                    </TextBlock>
                </StackPanel>

                <dx:SimpleButton Grid.Column="1" Content="İçerik Ekle" Height="40" Padding="25,0"
                                 Background="{StaticResource PrimaryBlue}" Foreground="White" FontWeight="Bold" CornerRadius="8"
                                 Glyph="/ZImages/add.svg" FontSize="14"
                                 Click="BtnAdd_Click" Cursor="Hand" VerticalAlignment="Center" GlyphHeight="24" GlyphWidth="24" GlyphToContentOffset="5"/>
            </Grid>
            
            <!-- Detaylı İstatistikler Paneli -->
            <Border x:Name="DetailedStatsPanel" Grid.Row="1" Background="{StaticResource SurfaceDark}" CornerRadius="12" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                    Padding="20" Margin="0,15,0,0" Visibility="Visible"
                    Cursor="Hand" MouseDown="DetailedStatsPanel_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Toplam Dizi - Mavi Tema -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📺" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Toplam Dizi" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTotalSeries" Text="0" Foreground="#60a5fa" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendTotalSeries" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- İzlenen Dizi - Yeşil Tema -->
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="✅" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="İzlenen Dizi" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtWatchedSeries" Text="0" Foreground="#10b981" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendWatchedSeries" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- İzleniyor - Turuncu Tema (YENİ) -->
                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="İzleniyor" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtWatchingSeries" Text="0" Foreground="#fb923c" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendWatchingSeries" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Toplam Bölüm - Mor Tema -->
                    <StackPanel Grid.Column="3" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🎬" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Toplam İzlenen Bölüm" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTotalEpisodesWatched" Text="0" Foreground="#a78bfa" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTotalWatchHours" Text="" Foreground="#64748b" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,4"/>
                            <TextBlock x:Name="TrendEpisodes" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Ortalama Rating - Sarı Tema -->
                    <StackPanel Grid.Column="4">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⭐" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ortalama Rating" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtAvgRating" Text="0.0" Foreground="#fbbf24" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendRating" Text="→" Foreground="#6b7280" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 2. TOOLBAR -->
        <Border Grid.Row="1" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Search -->
                    <ColumnDefinition Width="Auto"/> <!-- Tabs -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Right Buttons -->
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <dxe:TextEdit x:Name="TxtSearch" Grid.Column="0" Width="220" Height="42" 
                              Background="{StaticResource SurfaceDark}" Foreground="White" 
                              NullText="Dizi veya tür ara..." CornerRadius="8" BorderThickness="0" Padding="12,0" 
                              FontSize="13" EditValueChanged="TxtSearch_EditValueChanged" Margin="0,0,20,0"/>

                <!-- Filter Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Content="Tümü" IsChecked="True" Tag="Tümü" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="İzlendi" Tag="İzlendi" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="İzleniyor" Tag="İzleniyor" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="Listem" Tag="Listem" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="Yarım Bırakıldı" Tag="Yarım Bırakıldı" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                </StackPanel>

                <!-- Right Side Buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <dx:SimpleButton x:Name="BtnFilter" Content="Filtrele" Height="40" Margin="0,0,10,0" Padding="15,0"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" FontSize="13" FontWeight="Bold" Glyph="/ZImages/filter_list.svg"
                                     Click="BtnFilter_Click" Cursor="Hand" GlyphHeight="24" GlyphWidth="24"/>
                    <dx:SimpleButton x:Name="BtnSort" Content="Sırala" Height="40" Margin="0,0,5,0" Padding="15,0"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" FontSize="13" FontWeight="Bold" Glyph="/ZImages/sort.svg"
                                     Click="BtnSort_Click" Cursor="Hand" GlyphHeight="24" GlyphWidth="24"/>

                    <TextBlock Text="||" Foreground="{StaticResource TextGray}" FontSize="13" VerticalAlignment="Center" Margin="10,0,10,0"/>

                    <!-- View Toggles -->
                    <dx:SimpleButton x:Name="BtnViewGrid" Height="40" Width="40"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" Cursor="Hand" Click="BtnViewGrid_Click"
                                     Glyph="/ZImages/grid_view.svg" Margin="0,0,5,0" GlyphHeight="24" GlyphWidth="24"/>
                    <dx:SimpleButton x:Name="BtnViewList" Height="40" Width="40"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" Cursor="Hand" Click="BtnViewList_Click"
                                     Glyph="/ZImages/view_list.svg" Opacity="0.5" GlyphHeight="24" GlyphWidth="24"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter Popup -->
        <Popup x:Name="FilterPopup" PlacementTarget="{Binding ElementName=BtnFilter}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="10">
            <Border Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="20" Width="280">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Filtreleme Seçenekleri" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                    <!-- Puan Aralığı -->
                    <TextBlock Text="Puan Aralığı" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,15">
                        <dxe:CheckEdit Content="Şaheserler (9-10 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_9_10"/>
                        <dxe:CheckEdit Content="İyiler (7-8 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_7_8"/>
                        <dxe:CheckEdit Content="Ortalamalar (5-6 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_5_6"/>
                        <dxe:CheckEdit Content="Puanlanmamışlar" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_Unrated"/>
                    </StackPanel>

                    <Separator Background="{StaticResource BorderColor}" Opacity="0.5" Margin="0,0,0,15"/>

                    <!-- Sezon Sayısı -->
                    <TextBlock Text="Sezon Sayısı" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,15">
                        <dxe:CheckEdit Content="Kısa (1-2 Sezon)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Season_Short"/>
                        <dxe:CheckEdit Content="Orta (3-5 Sezon)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Season_Medium"/>
                        <dxe:CheckEdit Content="Uzun (6+ Sezon)" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Season_Long"/>
                    </StackPanel>

                    <Separator Background="{StaticResource BorderColor}" Opacity="0.5" Margin="0,0,0,15"/>

                    <!-- Yayın Yılı -->
                    <TextBlock Text="Yayın Yılı" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,15">
                        <dxe:CheckEdit Content="2020 ve Sonrası" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Year_2020"/>
                        <dxe:CheckEdit Content="2010 - 2019" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Year_2010"/>
                        <dxe:CheckEdit Content="2000 - 2009" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Year_2000"/>
                        <dxe:CheckEdit Content="Klasikler (&lt; 2000)" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Year_Classic"/>
                    </StackPanel>

                    <dx:SimpleButton Content="Filtreleri Temizle" Height="30" Margin="0,5,0,0" Background="Transparent" Foreground="{StaticResource PrimaryBlue}" 
                                     FontWeight="Bold" Cursor="Hand" Click="BtnClearFilters_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Sort Popup -->
        <Popup x:Name="SortPopup" PlacementTarget="{Binding ElementName=BtnSort}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="10">
            <Border Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="20" Width="260">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Sıralama" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                    <ListBox x:Name="SortListBox" Background="Transparent" BorderThickness="0" SelectionChanged="SortOption_Changed">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border" Padding="10,8" CornerRadius="6" Background="Transparent" Cursor="Hand">
                                                <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Foreground="White" FontSize="13"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#232f48"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBoxItem Content="Eklenme Tarihi (Yeni > Eski)" Tag="Date_Desc" IsSelected="True"/>
                        <ListBoxItem Content="Eklenme Tarihi (Eski > Yeni)" Tag="Date_Asc"/>
                        <ListBoxItem Content="İsim (A > Z)" Tag="Title_Asc"/>
                        <ListBoxItem Content="İsim (Z > A)" Tag="Title_Desc"/>
                        <ListBoxItem Content="Puan (Yüksek > Düşük)" Tag="Rating_Desc"/>
                        <ListBoxItem Content="Puan (Düşük > Yüksek)" Tag="Rating_Asc"/>
                        <ListBoxItem Content="Sezon (Çok > Az)" Tag="Season_Desc"/>
                        <ListBoxItem Content="Sezon (Az > Çok)" Tag="Season_Asc"/>
                        <ListBoxItem Content="Yayın Yılı (Yeni > Eski)" Tag="Year_Desc"/>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>

        <!-- 3. SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- HERO SECTION -->
                <Border Height="350" CornerRadius="16" Margin="0,0,0,25">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding FeaturedSeries.BackdropUrl}" Stretch="UniformToFill"/>
                    </Border.Background>

                    <Grid>
                        <Border CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#CC111827" Offset="0.6"/>
                                    <GradientStop Color="#FF111827" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <StackPanel VerticalAlignment="Bottom" Margin="35" HorizontalAlignment="Left" Width="550">
                            
                            <TextBlock Text="{Binding FeaturedSeries.Title}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding FeaturedSeries.Overview}" 
                                       FontSize="14" Foreground="#D1D5DB" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="22" MaxHeight="66" TextTrimming="CharacterEllipsis"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FeaturedSeries.RemainingText}" Foreground="#D1D5DB" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding FeaturedSeries.ProgressPercentage, StringFormat={}{0:0}%}" Foreground="#D1D5DB" FontSize="12"/>
                            </Grid>

                            <ProgressBar Value="{Binding FeaturedSeries.ProgressPercentage, Mode=OneWay}" Maximum="100"
                                         Style="{StaticResource ModernProgressBarStyle}" Margin="0,0,0,20"/>

                            <StackPanel Orientation="Horizontal">
                                <dx:SimpleButton Content="▶ Devam Et" Height="40" Padding="25,0"
                                                 Background="{StaticResource PrimaryBlue}" Foreground="White" FontWeight="Bold" 
                                                 CornerRadius="8" FontSize="13" Cursor="Hand" Margin="0,0,12,0"
                                                 Click="BtnContinueWatching_Click"/>
                                <dx:SimpleButton Content="ⓘ Daha Fazla" Height="40" Padding="25,0"
                                                 Background="#374151" Foreground="White" FontWeight="SemiBold" 
                                                 CornerRadius="8" FontSize="13" Cursor="Hand"
                                                 Click="BtnMoreInfo_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Section Header -->
                <Grid Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📺" Foreground="#3B82F6" FontSize="18" Margin="0,0,10,0"/>
                        <TextBlock Text="Dizi Listesi" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Grid>

                <!-- Series Cards Grid (Görünüm: Grid) -->
                <ItemsControl x:Name="SeriesGridControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate" Value="{StaticResource SeriesCardTemplate}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="Add">
                                                <Setter Property="ContentTemplate" Value="{StaticResource AddSeriesCardTemplate}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Series List (Görünüm: Liste) -->
                <ItemsControl x:Name="SeriesListControl" ItemsSource="{Binding FilteredSeries}"
                              ItemTemplate="{StaticResource SeriesListItemTemplate}" Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>