<UserControl x:Class="HobbyTracker.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:converters="clr-namespace:HobbyTracker.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200">

    <UserControl.Resources>
        <converters:AsyncImageConverter x:Key="AsyncImageConverter"/>
        <Storyboard x:Key="SlideUpFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <SolidColorBrush x:Key="BgDark" Color="#FF0C111A"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#161d2a"/>
        <SolidColorBrush x:Key="BorderColor" Color="#232f48"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2b6cee"/>
        <SolidColorBrush x:Key="TextGray" Color="#92a4c9"/>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#475569" BorderThickness="0" Width="6" Opacity="0.3">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#64748b"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Filter Tab Style -->
        <Style x:Key="ModernFilterTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <TextBlock x:Name="Text" Text="{TemplateBinding Content}" 
                                       Foreground="{TemplateBinding Foreground}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0"/>
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                                <Setter TargetName="Text" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Progress Bar Style -->
        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#232f48"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3">
                                <Border.Effect>
                                    <DropShadowEffect Color="#2b6cee" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Book List Item Template (List View) -->
        <DataTemplate x:Key="BookListItemTemplate">
            <Border Height="100" Margin="0,0,0,12" CornerRadius="12" 
                    Background="{StaticResource SurfaceDark}" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    Cursor="Hand"
                    PreviewMouseLeftButtonDown="BookCard_MouseDown">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" Opacity="0.2" ShadowDepth="2"/>
                </Border.Effect>

                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Kapak Görseli -->
                    <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True" Background="#0f1115">
                        <Image Source="{Binding CoverImageUrl, Converter={StaticResource AsyncImageConverter}, ConverterParameter=book}" 
                               Stretch="UniformToFill"/>
                    </Border>

                    <!-- Bilgiler -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title, FallbackValue=Kitap Adı}" Foreground="White" 
                                   FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                        <TextBlock Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,4">
                            <Run Text="{Binding Authors, Mode=OneWay, FallbackValue=Yazar}"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding PageCount, Mode=OneWay, StringFormat={}{0} sayfa}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Description}" Foreground="#6B7280" FontSize="11" 
                                   TextTrimming="CharacterEllipsis" MaxHeight="16"/>
                    </StackPanel>

                    <!-- Durum ve Puan -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="20,0,0,0">
                        <Border Background="{Binding StatusBadgeBackground}" CornerRadius="10" Padding="12,5" Margin="0,0,0,10">
                            <TextBlock Text="{Binding StatusDisplay}" Foreground="White" 
                                       FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Foreground="White" FontSize="14" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1}">
                                        <Binding Path="UserRating" FallbackValue="0"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BookCardTemplate">
            <Border Width="200" Height="370" Background="{StaticResource SurfaceDark}" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                    CornerRadius="12" Margin="0,0,20,20" Cursor="Hand"
                    PreviewMouseLeftButtonDown="BookCard_MouseDown">

                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="280"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Border CornerRadius="12" ClipToBounds="True" Background="#0f1115" Margin="4">
                            <Image Source="{Binding CoverImageUrl, Converter={StaticResource AsyncImageConverter}, ConverterParameter=book}" Stretch="UniformToFill"/>
                        </Border>

                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="14"
                                Background="{Binding StatusBadgeBackground}" 
                                BorderBrush="{Binding StatusColor}" BorderThickness="0"
                                CornerRadius="12" Padding="10,5">
                            <TextBlock Text="{Binding StatusDisplay}" Foreground="White" 
                                       FontSize="10" FontWeight="Bold"/>
                        </Border>

                        <Border CornerRadius="12,12,0,0" Opacity="0.2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0.6"/>
                                    <GradientStop Color="Black" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="12,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="1" Text="{Binding Authors}" Foreground="{StaticResource TextGray}" FontSize="12" Margin="0,2,0,8" TextTrimming="CharacterEllipsis"/>

                        <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="İlerleme" Foreground="{StaticResource TextGray}" FontSize="10"/>
                                <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0}%}" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}" Maximum="100" 
                                         Style="{StaticResource ModernProgressBarStyle}"
                                         Height="6" MinHeight="6" MaxHeight="6"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AddBookCardTemplate">
            <dx:SimpleButton Click="BtnAddBook_Click" Cursor="Hand" Width="200" Height="370" Margin="0,0,20,20" Padding="0">
                <dx:SimpleButton.Template>
                    <ControlTemplate TargetType="dx:SimpleButton">
                        <Border x:Name="MainBorder" CornerRadius="12" Background="Transparent" 
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="2">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#2b6cee" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#102b6cee" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <StackPanel x:Name="MainContent" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="60" Height="60" CornerRadius="30" Background="{StaticResource SurfaceDark}" Margin="0,0,0,15">
                                    <dx:DXImage Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_Add.svg'}" Width="32" Height="32"/>
                                </Border>
                                <TextBlock Text="Yeni Kitap Ekle" Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </dx:SimpleButton.Template>
            </dx:SimpleButton>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent" Margin="30">
        <Grid.RenderTransform>
            <TranslateTransform Y="20"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource SlideUpFadeIn}"/>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

            <!-- 1. HEADER (Title & Stats) -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Başlık ve Özet Alt Alta -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Kütüphane" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="StatsText"
                               FontSize="13"
                               Foreground="{StaticResource TextGray}"
                               Margin="0,4,0,0"
                               FontWeight="Bold"
                               Cursor="Hand"
                               MouseDown="StatsText_MouseDown">
                        Toplam 0 kitap • 0 okundu
                    </TextBlock>
                </StackPanel>

                <dx:SimpleButton Grid.Column="1" Content="İçerik Ekle" Height="40" Padding="25,0"
                                 Background="{StaticResource PrimaryBlue}" Foreground="White" FontWeight="Bold" CornerRadius="8"
                                 Glyph="/ZImages/add.svg" FontSize="14"
                                 Click="BtnAddBook_Click" Cursor="Hand" VerticalAlignment="Center" GlyphHeight="24" GlyphWidth="24"/>
            </Grid>

            <!-- Detaylı İstatistikler Paneli -->
            <Border x:Name="DetailedStatsPanel" Grid.Row="1" Background="{StaticResource SurfaceDark}" CornerRadius="12" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                    Padding="20" Margin="0,15,0,0" Visibility="Visible"
                    Cursor="Hand" MouseDown="DetailedStatsPanel_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Toplam Kitap - Mavi Tema -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📚" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Toplam Kitap" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTotalBooks" Text="0" Foreground="#60a5fa" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendTotalBooks" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Okunan Kitap - Yeşil Tema -->
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="✅" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Okunan Kitap" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtReadBooks" Text="0" Foreground="#10b981" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendReadBooks" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Okunuyor - Turuncu Tema (YENİ) -->
                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📖" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Okunuyor" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtReadingBooks" Text="0" Foreground="#fb923c" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendReadingBooks" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Toplam Sayfa - Mor Tema -->
                    <StackPanel Grid.Column="3" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📄" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Toplam Okunan Sayfa" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTotalPages" Text="0" Foreground="#a78bfa" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendPages" Text="↗" Foreground="#10b981" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Ortalama Rating - Sarı Tema -->
                    <StackPanel Grid.Column="4">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⭐" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ortalama Rating" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtAvgRating" Text="0.0" Foreground="#fbbf24" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="TrendRating" Text="→" Foreground="#6b7280" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 2. TOOLBAR (Search & Filters) -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderColor}" BorderThickness="0" Margin="0,0,0,25" Padding="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Search -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Tabs -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Buttons -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <dxe:TextEdit x:Name="TxtSearch" Grid.Column="0" Width="300" Height="42" 
                              Background="{StaticResource SurfaceDark}" Foreground="White" 
                              NullText="Kitap adı, yazar veya ISBN..." CornerRadius="8" BorderThickness="0" Padding="12,0" 
                              FontSize="13" EditValueChanged="TxtSearch_EditValueChanged" Margin="0,0,20,0"/>

                <!-- Filters Tabs (Moved next to Search) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Content="Tümü" IsChecked="True" Tag="Tümü" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="Okunuyor" Tag="Okunuyor" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="Okundu" Tag="Okundu" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="Okunacak" Tag="Okunacak" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                    <RadioButton Content="Yarım Bırakıldı" Tag="Yarım Bırakıldı" Style="{StaticResource ModernFilterTabStyle}" Checked="FilterRadioButton_Checked"/>
                </StackPanel>

                <!-- Right Side Buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Filter & Sort Buttons -->
                    <dx:SimpleButton x:Name="BtnFilter" Content="Filtrele" Height="40" Margin="0,0,10,0" Padding="15,0"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" FontSize="13" FontWeight="Bold" Glyph="/ZImages/filter_list.svg"
                                     Click="BtnFilter_Click" Cursor="Hand" GlyphHeight="24" GlyphWidth="24"/>
                    <dx:SimpleButton x:Name="BtnSort" Content="Sırala" Height="40" Margin="0,0,5,0" Padding="15,0"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" FontSize="13" FontWeight="Bold" Glyph="/ZImages/sort.svg"
                                     Click="BtnSort_Click" Cursor="Hand" GlyphHeight="24" GlyphWidth="24"/>

                    <TextBlock Text="||" Foreground="{StaticResource TextGray}" FontSize="13" VerticalAlignment="Center" Margin="10,0,10,0" Height="20" Width="7"/>

                    <!-- View Toggles -->
                    <dx:SimpleButton x:Name="BtnViewGrid" Height="40" Width="40"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" Cursor="Hand" Click="BtnViewGrid_Click"
                                     Glyph="/ZImages/grid_view.svg" Margin="0,0,5,0" GlyphHeight="24" GlyphWidth="24"/>

                    <dx:SimpleButton x:Name="BtnViewList" Height="40" Width="40"
                                     Background="{StaticResource SurfaceDark}" Foreground="{StaticResource TextGray}" 
                                     CornerRadius="10" Cursor="Hand" Click="BtnViewList_Click"
                                     Glyph="/ZImages/view_list.svg" Opacity="0.5" GlyphHeight="24" GlyphWidth="24"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filtreleme Popup (Overlay) -->
        <Popup x:Name="FilterPopup" PlacementTarget="{Binding ElementName=BtnFilter}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="10">
            <Border Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="20" Width="280">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Filtreleme Seçenekleri" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                    <!-- Puan Aralığı -->
                    <TextBlock Text="Puan Aralığı" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,15">
                        <dxe:CheckEdit Content="Şaheserler (9-10 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_9_10"/>
                        <dxe:CheckEdit Content="İyiler (7-8 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_7_8"/>
                        <dxe:CheckEdit Content="Ortalamalar (5-6 Puan)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_5_6"/>
                        <dxe:CheckEdit Content="Puanlanmamışlar" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Rating_Unrated"/>
                    </StackPanel>

                    <Separator Background="{StaticResource BorderColor}" Opacity="0.5" Margin="0,0,0,15"/>

                    <!-- Uzunluk -->
                    <TextBlock Text="Uzunluk (Sayfa Sayısı)" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,15">
                        <dxe:CheckEdit Content="Çerezlik (&lt; 150 sayfa)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Pages_Short"/>
                        <dxe:CheckEdit Content="Orta Boy (150 - 400 sayfa)" Foreground="White" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Pages_Medium"/>
                        <dxe:CheckEdit Content="Tuğla Gibi (&gt; 400 sayfa)" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Pages_Long"/>
                    </StackPanel>

                    <Separator Background="{StaticResource BorderColor}" Opacity="0.5" Margin="0,0,0,15"/>

                    <!-- Yazar -->
                    <TextBlock Text="Yazar" Foreground="{StaticResource TextGray}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <dxe:CheckEdit Content="Yazara Göre Grupla" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="Group_Author"/>

                    <dx:SimpleButton Content="Filtreleri Temizle" Height="30" Margin="0,15,0,0" Background="Transparent" Foreground="{StaticResource PrimaryBlue}" 
                                     FontWeight="Bold" Cursor="Hand" Click="BtnClearFilters_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Sıralama Popup (Overlay) -->
        <Popup x:Name="SortPopup" PlacementTarget="{Binding ElementName=BtnSort}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="10">
            <Border Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="20" Width="260">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Sıralama" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                    <ListBox x:Name="SortListBox" Background="Transparent" BorderThickness="0" SelectionChanged="SortOption_Changed">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border" Padding="10,8" CornerRadius="6" Background="Transparent" Cursor="Hand">
                                                <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Foreground="White" FontSize="13"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#232f48"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBoxItem Content="Eklenme Tarihi (Yeni > Eski)" Tag="Date_Desc" IsSelected="True"/>
                        <ListBoxItem Content="Eklenme Tarihi (Eski > Yeni)" Tag="Date_Asc"/>
                        <ListBoxItem Content="İsim (A > Z)" Tag="Title_Asc"/>
                        <ListBoxItem Content="İsim (Z > A)" Tag="Title_Desc"/>
                        <ListBoxItem Content="Puan (Yüksek > Düşük)" Tag="Rating_Desc"/>
                        <ListBoxItem Content="Puan (Düşük > Yüksek)" Tag="Rating_Asc"/>
                        <ListBoxItem Content="Sayfa Sayısı (Çok > Az)" Tag="Pages_Desc"/>
                        <ListBoxItem Content="Sayfa Sayısı (Az > Çok)" Tag="Pages_Asc"/>
                        <ListBoxItem Content="İlerleme (Bitiyor > Yeni)" Tag="Progress_Desc"/>
                        <ListBoxItem Content="İlerleme (Yeni > Bitiyor)" Tag="Progress_Asc"/>
                        <ListBoxItem Content="Basım Yılı (Yeni > Eski)" Tag="Year_Desc"/>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Hedef Belirleme Popup (Overlay) -->
        <Popup x:Name="GoalPopup" PlacementTarget="{Binding ElementName=BtnEditGoal}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="10">
            <Border Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="20" Width="280">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Yıllık Okuma Hedefi" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                    <TextBlock Text="Bu yıl kaç kitap okumak istersin?" Foreground="{StaticResource TextGray}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <dxe:SpinEdit x:Name="SpinGoal" Value="24" MinValue="1" MaxValue="1000" IsFloatValue="False" 
                                  Height="40" Margin="0,0,0,15" Mask="d" 
                                  Background="#111722" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalContentAlignment="Center"/>

                    <dx:SimpleButton Content="Kaydet" Height="36" Background="{StaticResource PrimaryBlue}" Foreground="White" FontWeight="Bold" 
                                     CornerRadius="8" Cursor="Hand" Click="BtnSaveGoal_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- 3. CONTENT AREA (Books & Sidebar) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Book Cards -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <Grid>
                    <!-- Grid Görünümü -->
                    <ItemsControl x:Name="BooksGridControl" HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="ContentTemplate" Value="{StaticResource BookCardTemplate}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="Add">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource AddBookCardTemplate}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Liste Görünümü -->
                    <ItemsControl x:Name="BooksListControl" ItemTemplate="{StaticResource BookListItemTemplate}" 
                                  HorizontalAlignment="Stretch" Visibility="Collapsed">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- Sidebar Widgets -->
            <StackPanel Grid.Column="1">
                <!-- Annual Goal -->
                <Border x:Name="Objective" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                        CornerRadius="16" Padding="24" Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Kitap Hedefim" FontWeight="Bold" Foreground="White" FontSize="16"/>
                            <dx:SimpleButton x:Name="BtnEditGoal" HorizontalAlignment="Right" Glyph="/ZImages/pencil.svg" BorderThickness="0"
                                             Width="24" Height="24" Opacity="0.5" Background="Transparent" Cursor="Hand" Click="BtnEditGoal_Click" GlyphHeight="24" GlyphWidth="24" GlyphToContentOffset="-1"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock x:Name="TxtFinishedCount" Text="0" FontSize="36" FontWeight="ExtraBold" Foreground="White" Margin="0,-6,0,0"/>
                            <TextBlock x:Name="TxtTotalGoal" Text="/ 24 Kitap" FontSize="14" Foreground="{StaticResource TextGray}" VerticalAlignment="Bottom" Margin="6,0,0,7"/>
                        </StackPanel>

                        <Grid Height="8" Margin="0,0,0,15">
                            <Border Background="#232f48" CornerRadius="4"/>
                            <Border x:Name="ProgressGoal" Background="{StaticResource PrimaryBlue}" CornerRadius="4" HorizontalAlignment="Left" Width="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#2b6cee" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="TxtGoalMessage" Text="Henüz başlamadın. Hadi bir kitap bitir!" 
                                   FontSize="12" Foreground="{StaticResource TextGray}" TextWrapping="Wrap" LineHeight="18"/>
                    </StackPanel>
                </Border>

                <!-- Favorite Authors -->
                <Border x:Name="FavAuthor" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                        CornerRadius="16" Padding="24">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Favori Yazarlar" FontWeight="Bold" Foreground="White" FontSize="16"/>
                        </Grid>

                        <ItemsControl x:Name="AuthorsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,16" Cursor="Hand" Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="42" Height="42" CornerRadius="21" Background="#F0F1F3">
                                            <TextBlock Text="{Binding Initials}" Foreground="#111827" FontWeight="ExtraBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding BookCountText}" Foreground="{StaticResource TextGray}" FontSize="12"/>
                                        </StackPanel>
                                        <dx:DXImage Grid.Column="2" Source="{dx:DXImage 'SvgImages/Arrows/Next.svg'}" Width="14" Opacity="0.4"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>