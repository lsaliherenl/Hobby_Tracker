<Window x:Name="EditPage" x:Class="HobbyTracker.Views.EditGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        
        Title="Oyun Düzenle" 
        Icon="/HT.ico"
        WindowState="Maximized" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                         <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="MainScale" Storyboard.TargetProperty="ScaleX" From="0.9" To="1" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="MainScale" Storyboard.TargetProperty="ScaleY" From="0.9" To="1" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2b6cee"/>
        <SolidColorBrush x:Key="BgDark" Color="#111722"/>
        <SolidColorBrush x:Key="PanelDark" Color="#1a2230"/>
        <SolidColorBrush x:Key="TextGray" Color="#92a4c9"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2a3447"/>

        <Style x:Key="DarkComboItemStyle" TargetType="dxe:ComboBoxEditItem">
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="Background" Value="#111722"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2b6cee"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Özel ScrollBar Style - AddGame ile uyumlu -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>

                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#64748b"
                                           BorderThickness="0"
                                           Width="8"
                                           Opacity="0.5">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4"
                                                                    BorderThickness="0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#94a3b8"/>
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#cbd5e1"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StarIconStyle" TargetType="Image">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="NoFocusTextEditStyle" TargetType="dxe:TextEdit">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ShowBorder" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#99000000" MouseDown="Background_MouseDown"/>

        <Border x:Name="MainBorder" Width="1100" Height="750" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="MainScale"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="60" ShadowDepth="20" Opacity="0.8"/>
            </Border.Effect>
            
            <!-- Köşeleri yuvarlatmak için Maske -->
            <Border.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Width="1100" Height="750" Background="Black" CornerRadius="24"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>

            <Grid>
                <!-- Tek arka plan: Solid renk -->
                <Grid>
                    <Rectangle Fill="#FF0C111A"/>
                </Grid>

                <!-- İçerik panelleri overlay -->
                <StackPanel Orientation="Horizontal">

                <Border Width="400" Background="#CC111722" CornerRadius="24,0,0,24" 
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1,1,0,1">

                    <Border.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Width="400" Height="750" Background="Black" CornerRadius="24,0,0,24"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>

                    <StackPanel VerticalAlignment="Center" Margin="30,0">
                        <!-- Oyun Resmi -->
                        <Border Width="340" Height="220" CornerRadius="16" BorderBrush="#33FFFFFF" BorderThickness="1" 
                                HorizontalAlignment="Center"
                                ClipToBounds="True" SnapsToDevicePixels="True">
                            <Border.OpacityMask>
                                <VisualBrush Stretch="Fill">
                                    <VisualBrush.Visual>
                                        <Border Width="340" Height="220" CornerRadius="16" Background="White"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Border.OpacityMask>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="8" Opacity="0.55"/>
                            </Border.Effect>
                            <Border CornerRadius="16" ClipToBounds="True" SnapsToDevicePixels="True" Background="#111722">
                                <Grid>
                                    <Image x:Name="ImgCover"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Source="{Binding CoverImageUrl}"
                                           ImageFailed="Image_ImageFailed"
                                           Loaded="ImgCover_Loaded"/>
                                    <TextBlock x:Name="CoverLoading"
                                               Text="⏳"
                                               FontSize="20"
                                               Foreground="#cbd5e1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                        </Border>
                        
                        <!-- Oyun Bilgileri -->
                        <StackPanel Margin="0,20,0,0">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="ORİJİNAL İSİM" FontSize="10" Foreground="{StaticResource TextGray}" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Title, TargetNullValue='Belirtilmemiş', FallbackValue='Belirtilmemiş'}" Foreground="White" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="YAPIMCI" FontSize="10" Foreground="{StaticResource TextGray}" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtDeveloper" Text="{Binding Developer, TargetNullValue='Bilinmiyor', FallbackValue='Bilinmiyor'}" Foreground="White" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="ÇIKIŞ TARİHİ" FontSize="10" Foreground="{StaticResource TextGray}" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtReleaseDate" Text="{Binding ReleaseDate, TargetNullValue='Bilinmiyor', FallbackValue='Bilinmiyor'}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="TÜRLER" FontSize="10" Foreground="{StaticResource TextGray}" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtGenres" Text="{Binding Genres, TargetNullValue='Tür bilgisi yok', FallbackValue='Tür bilgisi yok'}" Foreground="White" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <!-- Favorite Button -->
                            <Border x:Name="BtnFavorite" Height="44" CornerRadius="10" Background="#374151" 
                                    Cursor="Hand" MouseLeftButtonUp="BtnFavorite_Click" Margin="0,10,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4B5563"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtFavoriteIcon" Text="🤍" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtFavoriteLabel" Text="Favorilere Ekle" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Width="700" Background="#CC111722" CornerRadius="0,24,24,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,1,1" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Yıldız Seçimi Popup -->
                        <Popup x:Name="StarPopup"
                               PlacementTarget="{Binding ElementName=BtnStarSelect}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               VerticalOffset="6">
                            <Border Background="#1f2937" CornerRadius="10" Padding="10" BorderBrush="#334155" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl x:Name="StarItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="★"
                                                           FontSize="20"
                                                           Margin="4,0,4,0"
                                                           Cursor="Hand"
                                                           Foreground="#64748b"
                                                           MouseEnter="Star_MouseEnter"
                                                           MouseLeave="Star_MouseLeave"
                                                           MouseLeftButtonDown="Star_MouseLeftButtonUp"
                                                           Tag="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Grid Grid.Row="0" Margin="30,25,30,20">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Black" Foreground="White"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding Developer}" Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="Medium"/>
                                    <Ellipse Width="4" Height="4" Fill="#475569" Margin="10,0"/>
                                    <TextBlock Text="{Binding ReleaseYear}" Foreground="{StaticResource TextGray}" FontSize="14"/>
                                </StackPanel>
                            </StackPanel>

                            <dx:SimpleButton HorizontalAlignment="Right" VerticalAlignment="Top" Width="36" Height="36"
                                             Background="Transparent" Glyph="/ZImages/close.svg"
                                             Cursor="Hand" Click="BtnClose_Click" Opacity="0.7" GlyphHeight="24" GlyphWidth="24"/>
                        </Grid>
                        <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="{StaticResource BorderColor}" Opacity="0.5"/>

                        <ScrollViewer x:Name="GameInfo" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,5,0">
                            <StackPanel Margin="30">
                                <Border Background="#151c2a" CornerRadius="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="24" Margin="0,0,0,30">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <dx:DXImage Source="{dx:DXImage 'SvgImages/Format/Edit.svg'}" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="KİŞİSEL TAKİP &amp; DÜZENLEME" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid Margin="0,0,0,20">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="20"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row 0: Status & Platform -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="DURUM" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <Border Height="42" CornerRadius="8" Background="#111722" BorderThickness="1" BorderBrush="{StaticResource BorderColor}">
                                                    <dxe:ComboBoxEdit EditValue="{Binding Status}" 
                                                                      ShowBorder="False"
                                                                      Background="Transparent" 
                                                                      Foreground="White" 
                                                                      Padding="10,0" 
                                                                      IsTextEditable="False" 
                                                                      AllowDefaultButton="False" 
                                                                      ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                                                      VerticalContentAlignment="Center">
                                                        <dxe:ComboBoxEditItem Content="Oynuyor"/>
                                                        <dxe:ComboBoxEditItem Content="Tamamlandı"/>
                                                        <dxe:ComboBoxEditItem Content="İstek Listesi"/>
                                                        <dxe:ComboBoxEditItem Content="Bırakıldı"/>
                                                    </dxe:ComboBoxEdit>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="PLATFORM" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                                </StackPanel>
                                                <Border Height="42" CornerRadius="8" Background="#111722" BorderThickness="1" BorderBrush="{StaticResource BorderColor}">
                                                    <dxe:ComboBoxEdit x:Name="CmbPlatform" EditValue="{Binding Platform}"
                                                                      ShowBorder="False"
                                                                      Background="Transparent" 
                                                                      Foreground="White" 
                                                                      Padding="10,0" 
                                                                      IsTextEditable="False"
                                                                      AllowDefaultButton="False" 
                                                                      ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                                                      VerticalContentAlignment="Center">
                                                        <dxe:ComboBoxEditItem Content="PC (Steam)"/>
                                                        <dxe:ComboBoxEditItem Content="PlayStation 5"/>
                                                        <dxe:ComboBoxEditItem Content="Xbox Series X"/>
                                                        <dxe:ComboBoxEditItem Content="Nintendo Switch"/>
                                                        <dxe:ComboBoxEditItem Content="Mobil"/>
                                                    </dxe:ComboBoxEdit>
                                                </Border>
                                            </StackPanel>

                                            <!-- Row 2: Rating & PlayTime -->
                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="PUAN" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <dx:SimpleButton x:Name="BtnStarSelect"
                                                                 Height="42"
                                                                 Background="#111722"
                                                                 Foreground="White"
                                                                 CornerRadius="8"
                                                                 FontSize="13"
                                                                 Cursor="Hand"
                                                                 Padding="14,0"
                                                                 Click="BtnStarSelect_Click">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="★" Foreground="#fbbf24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="TxtStarRating" VerticalAlignment="Center">
                                                            <Run Text="{Binding UserRating, StringFormat={}{0:0}}"/>
                                                            <Run Text="/10"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </dx:SimpleButton>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="OYNAMA SÜRESİ" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <Border Height="42" CornerRadius="8" Background="#111722" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                                    <Grid>
                                                        <dx:DXImage Source="{dx:DXImage 'SvgImages/Scheduling/Time.svg'}" Width="16" HorizontalAlignment="Left" Margin="10,0,0,0" Opacity="0.5" Panel.ZIndex="1"/>
                                                        <dxe:SpinEdit EditValue="{Binding PlayTime}" 
                                                                      MinValue="0" 
                                                                      Increment="1" 
                                                                      ShowBorder="False"
                                                                      Background="Transparent" 
                                                                      Foreground="White" 
                                                                      BorderThickness="0" 
                                                                      HorizontalContentAlignment="Center" 
                                                                      FontWeight="Bold" 
                                                                      FontSize="14" 
                                                                      Margin="30,0,40,0"
                                                                      AllowDefaultButton="False"
                                                                      SelectAllOnGotFocus="True"/>
                                                        <TextBlock Text="saat" Foreground="{StaticResource TextGray}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Panel.ZIndex="1"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="YORUMUM" Foreground="{StaticResource TextGray}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <Border Height="120" Background="#0f172a" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8">
                                            <dxe:TextEdit Text="{Binding UserNotes}" VerticalContentAlignment="Top" 
                                                          ShowBorder="False"
                                                          Background="Transparent" Foreground="White" 
                                                          Padding="12" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True"
                                                          NullText="Oyun hakkındaki düşüncelerinizi buraya not alın..." Style="{StaticResource NoFocusTextEditStyle}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Background="#151c2a" CornerRadius="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="OYUN AÇIKLAMASI" Foreground="{StaticResource TextGray}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#cbd5e1" FontSize="14" LineHeight="22" Opacity="0.9" TextTrimming="CharacterEllipsis" MaxHeight="280"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="2" Margin="30,10,30,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <dx:SimpleButton Content="Oyunu Sil" Height="40" Background="Transparent" Foreground="#ef4444" FontWeight="Bold" FontSize="13" 
                                             Cursor="Hand" Click="BtnDelete_Click" Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Delete.svg'}" GlyphHeight="24" GlyphWidth="24"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <dx:SimpleButton Content="Vazgeç" Height="40" Width="100"
                                                 Background="#334155" Foreground="#cbd5e1" CornerRadius="8" FontWeight="SemiBold"
                                                 Cursor="Hand" Click="BtnClose_Click" GlyphHeight="24" GlyphWidth="24" Margin="0,0,15,0" Glyph="/ZImages/close.svg"/>
                                <dx:SimpleButton Content="Değişiklikleri Kaydet" Height="40" Padding="20,0"
                                                 Background="{StaticResource PrimaryBlue}" Foreground="White" CornerRadius="8" FontWeight="Bold"
                                                 Glyph="/ZImages/save.svg"
                                                 Cursor="Hand" Click="BtnSave_Click" GlyphHeight="24" GlyphWidth="24"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Custom Delete Confirmation Popup -->
        <Grid x:Name="DeletePopupOverlay" Visibility="Collapsed">
            <Border Background="#000000" Opacity="0.7"/>
            <Border Background="#161d2a" CornerRadius="16" 
                    Width="420" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
                </Border.Effect>
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="⚠️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Oyunu Sil" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Message -->
                    <TextBlock Grid.Row="1" x:Name="TxtDeleteMessage" 
                               Text="Bu oyunu silmek istediğinize emin misiniz? Bu işlem geri alınamaz."
                               Foreground="#92a4c9" FontSize="14" TextWrapping="Wrap" 
                               VerticalAlignment="Center"/>
                    
                    <!-- Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <dx:SimpleButton Content="İptal" Width="100" Height="38" Margin="0,0,10,0"
                                         Background="Transparent" Foreground="White" 
                                         BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                         CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                         Click="BtnCancelDelete_Click"/>
                        <dx:SimpleButton Content="Sil" Width="100" Height="38" 
                                         Background="#DC2626" Foreground="White" 
                                         CornerRadius="8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                         Click="BtnConfirmDelete_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>